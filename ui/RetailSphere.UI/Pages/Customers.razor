@page "/customers"
@using RetailSphere.Contracts.Customers
@attribute [Authorize]
@inject IApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Customers - RetailSphere</PageTitle>

@if (!_canView)
{
    <MudAlert Severity="Severity.Warning">You don't have permission to view customers.</MudAlert>
}
else
{

<PageHeader Title="Customers" Subtitle="People and businesses who buy from you." Breadcrumbs="_breadcrumbs">
    <Actions>
        @if (_canEdit)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="ShowCreateForm">
                New Customer
            </MudButton>
        }
    </Actions>
</PageHeader>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" md="4">
        <MudTextField T="string" Value="@_search" ValueChanged="OnSearchChanged" Label="Search by name, phone, or email"
                      Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="200" />
    </MudItem>
</MudGrid>

<MudTable Items="@FilteredCustomers" Hover="true" Dense="true" Loading="@_isLoading">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Phone</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Address</MudTh>
        <MudTh>Credit limit</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Phone">@(context.Phone ?? "—")</MudTd>
        <MudTd DataLabel="Email">@(context.Email ?? "—")</MudTd>
        <MudTd DataLabel="Address">@(context.Address ?? "—")</MudTd>
        <MudTd DataLabel="Credit limit">@(context.CreditLimit.HasValue ? context.CreditLimit.Value.ToString("0.00") : "Unlimited")</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                @(context.IsActive ? "Active" : "Inactive")
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Actions">
            @if (_canEdit)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => ShowEditForm(context))" />
                @if (context.IsActive)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PauseCircle" Size="Size.Small" OnClick="@(() => DeactivateAsync(context.Id))" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" OnClick="@(() => ActivateAsync(context.Id))" />
                }
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => ConfirmDeleteAsync(context))" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <EmptyState Icon="@Icons.Material.Filled.Groups" Title="@(string.IsNullOrWhiteSpace(_search) ? "No customers yet" : "No matching customers")"
                    Description="@(string.IsNullOrWhiteSpace(_search) ? "Add your first customer to start recording sales and payments for them." : "Try a different name, phone, or email.")" />
    </NoRecordsContent>
    <LoadingContent>
        <TableSkeleton Rows="5" />
    </LoadingContent>
</MudTable>

<MudDialog @bind-Visible="_showForm" Options="AppDialogOptions.Default">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingId is null ? "New Customer" : "Edit Customer")</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_formName" Label="Name" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formPhone" Label="Phone" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formEmail" Label="Email" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_formAddress" Label="Address" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudNumericField @bind-Value="_formCreditLimit" Label="Credit limit (leave blank for unlimited)" Variant="Variant.Outlined" Min="0" Format="0.00" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelForm">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_isSaving">Save</MudButton>
    </DialogActions>
</MudDialog>

}

@code {
    private static readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", href: "/"),
        new("Customers", href: null),
    ];

    private IReadOnlyList<CustomerDto> _customers = [];
    private HashSet<string> _permissions = [];

    private bool _isLoading = true;
    private bool _isSaving;
    private bool _showForm;
    private long? _editingId;
    private string _search = string.Empty;

    private string _formName = string.Empty;
    private string? _formPhone;
    private string? _formEmail;
    private string? _formAddress;
    private decimal? _formCreditLimit;

    private bool _canView => _permissions.Contains("customers.view");
    private bool _canEdit => _permissions.Contains("customers.edit");

    private IReadOnlyList<CustomerDto> FilteredCustomers =>
        string.IsNullOrWhiteSpace(_search)
            ? _customers
            : _customers.Where(c =>
                c.Name.Contains(_search, StringComparison.InvariantCultureIgnoreCase)
                || (c.Phone?.Contains(_search, StringComparison.InvariantCultureIgnoreCase) ?? false)
                || (c.Email?.Contains(_search, StringComparison.InvariantCultureIgnoreCase) ?? false))
              .ToList();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _permissions = state.User.FindAll("permission").Select(c => c.Value).ToHashSet();

        if (_canView)
        {
            await LoadAsync();
        }
        else
        {
            _isLoading = false;
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        var result = await ApiClient.GetCustomersAsync(includeInactive: true);
        if (result.Success && result.Data is not null)
        {
            _customers = result.Data;
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to load customers.", Severity.Error);
        }
        _isLoading = false;
    }

    private void OnSearchChanged(string value) => _search = value;

    private void ShowCreateForm()
    {
        _editingId = null;
        _formName = string.Empty;
        _formPhone = null;
        _formEmail = null;
        _formAddress = null;
        _formCreditLimit = null;
        _showForm = true;
    }

    private void ShowEditForm(CustomerDto customer)
    {
        _editingId = customer.Id;
        _formName = customer.Name;
        _formPhone = customer.Phone;
        _formEmail = customer.Email;
        _formAddress = customer.Address;
        _formCreditLimit = customer.CreditLimit;
        _showForm = true;
    }

    private void CancelForm() => _showForm = false;

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            Snackbar.Add("Customer name is required.", Severity.Warning);
            return;
        }

        _isSaving = true;

        var result = _editingId is null
            ? await ApiClient.CreateCustomerAsync(new CreateCustomerRequest
            {
                Name = _formName,
                Phone = _formPhone,
                Email = _formEmail,
                Address = _formAddress,
                CreditLimit = _formCreditLimit,
            })
            : await ApiClient.UpdateCustomerAsync(_editingId.Value, new UpdateCustomerRequest
            {
                Name = _formName,
                Phone = _formPhone,
                Email = _formEmail,
                Address = _formAddress,
            });

        if (!result.Success)
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to save customer.", Severity.Error);
            _isSaving = false;
            return;
        }

        // UpdateCustomerRequest (the general edit) doesn't carry CreditLimit — applied
        // via the dedicated endpoint right after, same two-call-one-dialog approach
        // used on the Suppliers page for CreditLimit/PaymentTerms.
        if (_editingId is not null)
        {
            var creditResult = await ApiClient.UpdateCustomerCreditLimitAsync(_editingId.Value, new UpdateCustomerCreditLimitRequest
            {
                CreditLimit = _formCreditLimit,
            });

            if (!creditResult.Success)
            {
                Snackbar.Add(creditResult.Error?.Message ?? "Customer saved, but credit limit failed to update.", Severity.Warning);
                _isSaving = false;
                _showForm = false;
                await LoadAsync();
                return;
            }
        }

        Snackbar.Add("Customer saved.", Severity.Success);
        _showForm = false;
        await LoadAsync();
        _isSaving = false;
    }

    private async Task ActivateAsync(long id)
    {
        var result = await ApiClient.ActivateCustomerAsync(id);
        if (result.Success)
        {
            Snackbar.Add("Customer activated.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to activate customer.", Severity.Error);
        }
    }

    private async Task DeactivateAsync(long id)
    {
        var result = await ApiClient.DeactivateCustomerAsync(id);
        if (result.Success)
        {
            Snackbar.Add("Customer deactivated.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to deactivate customer.", Severity.Error);
        }
    }

    private async Task ConfirmDeleteAsync(CustomerDto customer)
    {
        if (!await DialogService.ConfirmDeleteAsync($"'{customer.Name}'"))
            return;

        var result = await ApiClient.DeleteCustomerAsync(customer.Id);
        if (result.Success)
        {
            Snackbar.Add("Customer deleted.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to delete customer.", Severity.Error);
        }
    }
}
