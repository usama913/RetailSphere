@page "/admin/roles"
@attribute [Authorize]
@inject IApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Roles - RetailSphere</PageTitle>

@if (!_canView)
{
    <MudAlert Severity="Severity.Warning">You don't have permission to view roles.</MudAlert>
}
else
{

<PageHeader Title="Roles &amp; Permissions" Subtitle="Bundles of permissions assigned to users." Breadcrumbs="_breadcrumbs">
    <Actions>
        @if (_canCreate)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="ShowCreateForm">
                New Role
            </MudButton>
        }
    </Actions>
</PageHeader>

<MudTable Items="@_roles" Hover="true" Dense="true" Loading="@_isLoading">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Type</MudTh>
        <MudTh>Permissions</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Description">@context.Description</MudTd>
        <MudTd DataLabel="Type">
            <MudChip T="string" Size="Size.Small" Color="@(context.IsSystemRole ? Color.Secondary : Color.Default)">
                @(context.IsSystemRole ? "System" : "Custom")
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Permissions">@context.PermissionIds.Count</MudTd>
        <MudTd DataLabel="Actions">
            @if (_canEdit && !context.IsSystemRole)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => ShowEditForm(context))" />
            }
            @if (_canDelete && !context.IsSystemRole)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => ConfirmDeleteAsync(context))" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <EmptyState Icon="@Icons.Material.Filled.Security" Title="No custom roles yet"
                    Description="Create a role to group permissions together, then assign it to users." />
    </NoRecordsContent>
    <LoadingContent>
        <TableSkeleton Rows="4" />
    </LoadingContent>
</MudTable>

<MudDialog @bind-Visible="_showForm" Options="AppDialogOptions.Large">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingId is null ? "New Role" : "Edit Role")</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formName" Label="Name" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formDescription" Label="Description" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Permissions</MudText>
        @foreach (var group in _permissionsByModule)
        {
            <MudText Typo="Typo.subtitle2" Class="mt-3" Style="color: var(--mud-palette-primary);">@group.Key</MudText>
            <MudGrid>
                @foreach (var permission in group.Value)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCheckBox T="bool"
                                     Value="@_selectedPermissionIds.Contains(permission.Id)"
                                     ValueChanged="@((bool v) => TogglePermission(permission.Id, v))"
                                     Label="@permission.DisplayName"
                                     Dense="true" />
                    </MudItem>
                }
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelForm">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_isSaving">Save</MudButton>
    </DialogActions>
</MudDialog>

}

@code {
    private static readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", href: "/"),
        new("Administration", href: null),
        new("Roles & Permissions", href: null),
    ];

    private IReadOnlyList<RoleDto> _roles = [];
    private IReadOnlyList<PermissionDto> _allPermissions = [];
    private Dictionary<string, List<PermissionDto>> _permissionsByModule = new();
    private HashSet<long> _selectedPermissionIds = [];
    private HashSet<string> _permissions = [];

    private bool _isLoading = true;
    private bool _isSaving;
    private bool _showForm;
    private long? _editingId;

    private string _formName = string.Empty;
    private string? _formDescription;

    private bool _canView => _permissions.Contains("admin.roles.view");
    private bool _canCreate => _permissions.Contains("admin.roles.create");
    private bool _canEdit => _permissions.Contains("admin.roles.edit");
    private bool _canDelete => _permissions.Contains("admin.roles.delete");

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _permissions = state.User.FindAll("permission").Select(c => c.Value).ToHashSet();

        if (_canView)
        {
            await LoadAsync();
        }
        else
        {
            _isLoading = false;
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        var rolesResult = await ApiClient.GetRolesAsync();
        if (rolesResult.Success && rolesResult.Data is not null)
        {
            _roles = rolesResult.Data;
        }
        else
        {
            Snackbar.Add(rolesResult.Error?.Message ?? "Failed to load roles.", Severity.Error);
        }

        var permissionsResult = await ApiClient.GetPermissionsAsync();
        if (permissionsResult.Success && permissionsResult.Data is not null)
        {
            _allPermissions = permissionsResult.Data;
            _permissionsByModule = _allPermissions
                .GroupBy(p => p.Module)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        else
        {
            Snackbar.Add(permissionsResult.Error?.Message ?? "Failed to load permissions.", Severity.Error);
        }

        _isLoading = false;
    }

    private void TogglePermission(long permissionId, bool isSelected)
    {
        if (isSelected)
        {
            _selectedPermissionIds.Add(permissionId);
        }
        else
        {
            _selectedPermissionIds.Remove(permissionId);
        }
    }

    private void ShowCreateForm()
    {
        _editingId = null;
        _formName = string.Empty;
        _formDescription = null;
        _selectedPermissionIds = [];
        _showForm = true;
    }

    private void ShowEditForm(RoleDto role)
    {
        _editingId = role.Id;
        _formName = role.Name;
        _formDescription = role.Description;
        _selectedPermissionIds = role.PermissionIds.ToHashSet();
        _showForm = true;
    }

    private void CancelForm() => _showForm = false;

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            Snackbar.Add("Role name is required.", Severity.Warning);
            return;
        }

        _isSaving = true;

        var permissionIds = _selectedPermissionIds.ToList();

        var result = _editingId is null
            ? await ApiClient.CreateRoleAsync(new CreateRoleRequest
            {
                Name = _formName,
                Description = _formDescription,
                PermissionIds = permissionIds,
            })
            : await ApiClient.UpdateRoleAsync(_editingId.Value, new UpdateRoleRequest
            {
                Name = _formName,
                Description = _formDescription,
                PermissionIds = permissionIds,
            });

        if (result.Success)
        {
            Snackbar.Add("Role saved.", Severity.Success);
            _showForm = false;
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to save role.", Severity.Error);
        }

        _isSaving = false;
    }

    private async Task ConfirmDeleteAsync(RoleDto role)
    {
        if (!await DialogService.ConfirmDeleteAsync($"the '{role.Name}' role", "Any users currently assigned this role will lose the permissions it grants."))
            return;

        var result = await ApiClient.DeleteRoleAsync(role.Id);
        if (result.Success)
        {
            Snackbar.Add("Role deleted.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to delete role.", Severity.Error);
        }
    }
}
