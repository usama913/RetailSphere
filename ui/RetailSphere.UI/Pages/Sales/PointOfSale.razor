@page "/sales/pos"
@using RetailSphere.Contracts.Admin
@using RetailSphere.Contracts.Catalog
@using RetailSphere.Contracts.Customers
@using RetailSphere.Contracts.Finance
@using RetailSphere.Contracts.Sales
@attribute [Authorize]
@inject IApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime

<PageTitle>Point of Sale - RetailSphere</PageTitle>

@if (!_canUse)
{
    <MudAlert Severity="Severity.Warning">You don't have permission to use Point of Sale.</MudAlert>
}
else
{

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4" Wrap="Wrap.Wrap">
    <div>
        <MudText Typo="Typo.h5">Point of Sale</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Ring up a sale and check out.</MudText>
    </div>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
        @if (_canRecordExpense)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.ReceiptLong"
                       OnClick="@(() => _showQuickAddExpense = !_showQuickAddExpense)">
                Add Expense
            </MudButton>
        }
        <div style="min-width:220px">
            <MudSelect T="long?" Value="_branchId" ValueChanged="OnBranchChangedAsync" Label="Branch" Variant="Variant.Outlined" Margin="Margin.Dense">
                @foreach (var branch in _branches)
                {
                    <MudSelectItem T="long?" Value="@((long?)branch.Id)">@branch.Name</MudSelectItem>
                }
            </MudSelect>
        </div>
    </MudStack>
</MudStack>

@if (_showQuickAddExpense)
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-3">Add Expense</MudText>
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudNumericField @bind-Value="_expAmount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudSelect T="string" @bind-Value="_expCategory" Label="Category" Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex:1">
                        @foreach (var category in _categoryOptions)
                        {
                            <MudSelectItem T="string" Value="@category">@category</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTooltip Text="Add a new category">
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="@(() => _showAddExpenseCategory = !_showAddExpenseCategory)" />
                    </MudTooltip>
                </MudStack>
                @if (_showAddExpenseCategory)
                {
                    <MudStack Row="true" Spacing="1" Class="mt-2" AlignItems="AlignItems.Center">
                        <MudTextField @bind-Value="_newExpenseCategoryName" Label="New category name" Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex:1" />
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="AddNewExpenseCategory">Add</MudButton>
                    </MudStack>
                }
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="d-flex align-center">
                <MudCheckBox @bind-Value="_expPaidFromCash" Label="Paid from cash drawer" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudTextField @bind-Value="_expDescription" Label="Description (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>
        <MudStack Row="true" Class="mt-3" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveExpenseAsync" Disabled="@(_isSavingExpense || _branchId is null)">
                Save Expense
            </MudButton>
            <MudButton Variant="Variant.Text" OnClick="@(() => _showQuickAddExpense = false)">Cancel</MudButton>
        </MudStack>
        @if (_branchId is null)
        {
            <MudText Typo="Typo.caption" Class="mt-2" Style="color: var(--mud-palette-error);">Select a branch first.</MudText>
        }
    </MudPaper>
}

@if (_branchId is not null)
{
    @if (_currentSession is null)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            No cash register session is open for this branch.
            @if (_canOperateRegister)
            {
                <MudButton Variant="Variant.Text" Size="Size.Small" Class="ml-2" OnClick="@(() => NavigationManager.NavigateTo("finance/cash-register"))">Open one</MudButton>
            }
        </MudAlert>
    }
    else
    {
        <MudPaper Class="pa-3 mb-4" Elevation="1" Style="border-left: 4px solid var(--mud-palette-success);">
            <MudStack Row="true" Spacing="6" Wrap="Wrap.Wrap">
                <div>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Opening Balance</MudText>
                    <MudText Typo="Typo.h6">@_currentSession.OpeningBalance.ToString("0.00")</MudText>
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Current Cash Balance</MudText>
                    <MudText Typo="Typo.h6">@(_currentSession.CurrentCashBalance?.ToString("0.00") ?? "—")</MudText>
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Opened</MudText>
                    <MudText Typo="Typo.body2">@_currentSession.OpenedAtUtc.ToLocalTime().ToString("g") by @(_currentSession.OpenedByUserName ?? "—")</MudText>
                </div>
            </MudStack>
        </MudPaper>
    }
}

@if (_lastCompletedOrder is not null)
{
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
            <MudText Typo="Typo.h6" Color="Color.Success">Sale completed — @_lastCompletedOrder.OrderNumber</MudText>
            <MudStack Row="true" Spacing="1">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Print" OnClick="PrintReceiptAsync">Print</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.PictureAsPdf" OnClick="PrintReceiptAsync">Download PDF</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Share" OnClick="ShareReceiptAsync">Share</MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => _lastCompletedOrder = null)">Dismiss</MudButton>
            </MudStack>
        </MudStack>

        <div id="pos-receipt" style="max-width:380px; margin:0 auto; font-family:monospace;">
            <MudStack AlignItems="AlignItems.Center" Spacing="0" Class="mb-2">
                <MudText Typo="Typo.subtitle1"><strong>@(_lastCompletedOrder.BranchName ?? "RetailSphere")</strong></MudText>
                <MudText Typo="Typo.caption">Receipt — @_lastCompletedOrder.OrderNumber</MudText>
                <MudText Typo="Typo.caption">@_lastCompletedOrder.OrderDate.ToLocalTime().ToString("g")</MudText>
            </MudStack>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.caption">Cashier: @(_lastCompletedOrder.CashierName ?? "—")</MudText>
            <MudText Typo="Typo.caption">Customer: @(_lastCompletedOrder.CustomerName ?? "Walk-in")</MudText>
            <MudDivider Class="my-2" />
            @foreach (var line in _lastCompletedOrder.Lines)
            {
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.body2">@line.DescriptionSnapshot x @line.Quantity.ToString("0.###")</MudText>
                    <MudText Typo="Typo.body2">@line.LineTotal.ToString("0.00")</MudText>
                </MudStack>
            }
            <MudDivider Class="my-2" />
            <MudStack Spacing="0">
                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Subtotal</MudText><MudText Typo="Typo.body2">@_lastCompletedOrder.SubtotalAmount.ToString("0.00")</MudText></MudStack>
                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Tax</MudText><MudText Typo="Typo.body2">@_lastCompletedOrder.TaxAmount.ToString("0.00")</MudText></MudStack>
                @if (_lastCompletedOrder.OrderDiscountAmount > 0)
                {
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Discount</MudText><MudText Typo="Typo.body2">-@_lastCompletedOrder.OrderDiscountAmount.ToString("0.00")</MudText></MudStack>
                }
                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.subtitle1"><strong>Total</strong></MudText><MudText Typo="Typo.subtitle1"><strong>@_lastCompletedOrder.TotalAmount.ToString("0.00")</strong></MudText></MudStack>
                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Paid (@_lastCompletedOrder.PaymentMethod)</MudText><MudText Typo="Typo.body2">@_lastCompletedOrder.AmountPaid.ToString("0.00")</MudText></MudStack>
                @if (_lastCompletedOrder.OutstandingBalance > 0)
                {
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Outstanding</MudText><MudText Typo="Typo.body2">@_lastCompletedOrder.OutstandingBalance.ToString("0.00")</MudText></MudStack>
                }
                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Change due</MudText><MudText Typo="Typo.body2">@_lastCompletedOrder.ChangeDue.ToString("0.00")</MudText></MudStack>
            </MudStack>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.caption" Style="display:block; text-align:center;">Thank you for your purchase!</MudText>
        </div>
    </MudPaper>
}

<MudGrid>
    <MudItem xs="12" md="8">
        <MudPaper Class="pa-4 mb-4" Elevation="1">
            <MudTextField @ref="_searchField" T="string" Value="@_searchTerm" ValueChanged="OnSearchChanged" Label="Search products by name, SKU, or barcode"
                          Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" DebounceInterval="150" Placeholder="Start typing to find an item… (Enter adds an exact match)"
                          @onkeydown="OnSearchKeyDown" />

            @if (!string.IsNullOrWhiteSpace(_searchTerm))
            {
                @if (GetSearchResults().Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">No matching items.</MudText>
                }
                else
                {
                    <MudTable Items="@GetSearchResults()" Hover="true" Dense="true" Class="mt-2">
                        <HeaderContent>
                            <MudTh>Product</MudTh>
                            <MudTh>Variant</MudTh>
                            <MudTh>SKU</MudTh>
                            <MudTh>Price</MudTh>
                            <MudTh>Available</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Product">@context.Product.Name</MudTd>
                            <MudTd DataLabel="Variant">@GetAttributeLabel(context.Variant)</MudTd>
                            <MudTd DataLabel="SKU">@context.Variant.Sku</MudTd>
                            <MudTd DataLabel="Price">@context.Variant.Price.ToString("0.00")</MudTd>
                            <MudTd DataLabel="Available">@GetAvailableQty(context.Variant.Id).ToString("0.###")</MudTd>
                            <MudTd>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="@(() => AddToCart(context.Product, context.Variant))" Disabled="@GetAvailableQty(context.Variant.Id).Equals(0m)">
                                    Add
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            }
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-2">Cart</MudText>
            @if (_cart.Count == 0)
            {
                <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Search for an item above to add it to the cart.</MudText>
            }
            else
            {
                <MudTable Items="@_cart" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Item</MudTh>
                        <MudTh>Qty</MudTh>
                        <MudTh>Unit price</MudTh>
                        <MudTh>Discount</MudTh>
                        <MudTh>Line total</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Item">
                            <MudText Typo="Typo.body2">@context.Description</MudText>
                            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@context.Sku</MudText>
                        </MudTd>
                        <MudTd DataLabel="Qty">
                            <MudNumericField T="decimal" Value="@context.Quantity" ValueChanged="@(v => SetCartQuantity(context, v))"
                                              Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.001M" Style="width:90px" />
                        </MudTd>
                        <MudTd DataLabel="Unit price">@context.UnitPrice.ToString("0.00")</MudTd>
                        <MudTd DataLabel="Discount">
                            <MudNumericField T="decimal" Value="@context.DiscountAmount" ValueChanged="@(v => SetCartDiscount(context, v))"
                                              Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Style="width:90px" />
                        </MudTd>
                        <MudTd DataLabel="Line total">@GetLineTotal(context).ToString("0.00")</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => RemoveFromCart(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4 mb-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-2">Customer</MudText>
            <MudSelect T="long?" Value="_customerId" ValueChanged="OnCustomerChangedAsync" Label="Customer" Variant="Variant.Outlined" Margin="Margin.Dense">
                <MudSelectItem T="long?" Value="@((long?)null)">Walk-in customer</MudSelectItem>
                @foreach (var customer in _customers)
                {
                    <MudSelectItem T="long?" Value="@((long?)customer.Id)">@customer.Name@(string.IsNullOrWhiteSpace(customer.Phone) ? "" : $" ({customer.Phone})")</MudSelectItem>
                }
            </MudSelect>
            <MudButton Variant="Variant.Text" Size="Size.Small" Class="mt-1" OnClick="@(() => _showQuickAddCustomer = !_showQuickAddCustomer)">
                + New customer
            </MudButton>

            @if (_showQuickAddCustomer)
            {
                <MudPaper Class="pa-3 mt-2" Elevation="0" Style="border: 1px solid var(--mud-palette-table-lines);">
                    <MudTextField @bind-Value="_qacName" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                    <MudTextField @bind-Value="_qacPhone" Label="Phone" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" />
                    <MudTextField @bind-Value="_qacEmail" Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="mt-2" OnClick="CreateQuickCustomerAsync" Disabled="@_isSavingQuickCustomer">
                        Save Customer
                    </MudButton>
                </MudPaper>
            }

            @if (_customerCreditSummary is not null)
            {
                <MudPaper Class="pa-3 mt-3" Elevation="0" Style="border: 1px solid var(--mud-palette-table-lines);">
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Credit standing</MudText>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Outstanding</MudText><MudText Typo="Typo.body2">@_customerCreditSummary.CurrentOutstandingBalance.ToString("0.00")</MudText></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Credit limit</MudText><MudText Typo="Typo.body2">@(_customerCreditSummary.CreditLimit.HasValue ? _customerCreditSummary.CreditLimit.Value.ToString("0.00") : "Unlimited")</MudText></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Available credit</MudText><MudText Typo="Typo.body2">@(_customerCreditSummary.AvailableCredit.HasValue ? _customerCreditSummary.AvailableCredit.Value.ToString("0.00") : "—")</MudText></MudStack>
                    @if (_customerCreditSummary.TotalOverdueAmount > 0)
                    {
                        <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2" Style="color: var(--mud-palette-error);">Overdue</MudText><MudText Typo="Typo.body2" Style="color: var(--mud-palette-error);">@_customerCreditSummary.TotalOverdueAmount.ToString("0.00")</MudText></MudStack>
                    }
                    @if (_customerCreditSummary.IsOverCreditLimit)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">This customer is already over their credit limit.</MudAlert>
                    }
                </MudPaper>
            }
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-2">Payment</MudText>

            <MudSelect T="string" Value="_paymentMethod" ValueChanged="OnPaymentMethodChanged" Label="Payment method" Variant="Variant.Outlined" Margin="Margin.Dense">
                @foreach (var method in PaymentMethods)
                {
                    <MudSelectItem T="string" Value="@method">@method</MudSelectItem>
                }
            </MudSelect>

            @if (IsCreditSale)
            {
                <MudGrid Class="mt-1">
                    <MudItem xs="12" sm="6">
                        <MudDatePicker @bind-Date="_dueDate" Label="Due date" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" @bind-Value="_paymentTerms" Label="Payment terms" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem T="string" Value='@("Net 15")'>Net 15</MudSelectItem>
                            <MudSelectItem T="string" Value='@("Net 30")'>Net 30</MudSelectItem>
                            <MudSelectItem T="string" Value='@("Net 45")'>Net 45</MudSelectItem>
                            <MudSelectItem T="string" Value='@("Net 60")'>Net 60</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
                @if (_customerId is null)
                {
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-error);">Select a customer to allow a credit or split sale.</MudText>
                }
            }

            <MudNumericField T="decimal" Value="_orderDiscountAmount" ValueChanged="OnOrderDiscountChanged" Label="Order discount" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Class="mt-2" />

            <MudDivider Class="my-3" />
            <MudStack Spacing="1">
                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Subtotal</MudText><MudText Typo="Typo.body2">@GetSubtotal().ToString("0.00")</MudText></MudStack>
                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Tax</MudText><MudText Typo="Typo.body2">@GetTaxTotal().ToString("0.00")</MudText></MudStack>
                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.subtitle1"><strong>Total</strong></MudText><MudText Typo="Typo.subtitle1"><strong>@GetTotal().ToString("0.00")</strong></MudText></MudStack>
            </MudStack>
            <MudDivider Class="my-3" />

            <MudNumericField T="decimal" Value="_amountPaid" ValueChanged="OnAmountPaidChanged" Label="Amount paid" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0"
                              HelperText="@(_amountPaidTouched ? null : "Pre-filled with the total — edit if the customer pays a different amount")" />
            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-2">
                <MudText Typo="Typo.body2">Change due</MudText>
                <MudText Typo="Typo.body2">@GetChangeDue().ToString("0.00")</MudText>
            </MudStack>
            @if (GetTotal() - _amountPaid > 0)
            {
                <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-1">
                    <MudText Typo="Typo.body2">Outstanding (on account)</MudText>
                    <MudText Typo="Typo.body2">@(GetTotal() - _amountPaid).ToString("0.00")</MudText>
                </MudStack>
            }

            <MudTextField @bind-Value="_notes" Label="Notes (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" Lines="2" />

            @if (_showCreditOverrideConfirm)
            {
                <MudAlert Severity="Severity.Warning" Class="mt-3">
                    @_creditOverrideMessage
                    @if (_canOverrideCreditLimit)
                    {
                        <div class="mt-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="@(() => CheckoutAsync(overrideCreditLimit: true))" Disabled="@_isCheckingOut">
                                Proceed Anyway
                            </MudButton>
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => _showCreditOverrideConfirm = false)">Cancel</MudButton>
                        </div>
                    }
                </MudAlert>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="mt-3" Size="Size.Large"
                       OnClick="@(() => CheckoutAsync(overrideCreditLimit: false))" Disabled="@(_isCheckingOut || _cart.Count == 0 || _branchId is null)">
                Checkout
            </MudButton>
        </MudPaper>
    </MudItem>
</MudGrid>

}

@code {
    private sealed class CartLine
    {
        public required long ProductId { get; init; }
        public required long ProductVariantId { get; init; }
        public required string Sku { get; init; }
        public required string Description { get; init; }
        public required decimal UnitPrice { get; init; }
        public required decimal TaxRate { get; init; }
        public required string TaxType { get; init; }
        public decimal Quantity { get; set; } = 1;
        public decimal DiscountAmount { get; set; }
    }

    private static readonly IReadOnlyList<string> PaymentMethods = ["Cash", "Card", "Bank Transfer", "Mobile Payment", "Credit", "Split"];
    private static readonly IReadOnlyList<string> DefaultExpenseCategories = ["Rent", "Utilities", "Salaries", "Supplies", "Maintenance", "Marketing", "Other"];

    // Bulk-fetched once per branch change — same simplification as the Inventory
    // Overview/Branch Stock summary cards (client-side search over a capped fetch
    // rather than a dedicated server-side product-search endpoint).
    private const int BulkFetchLimit = 2000;

    private IReadOnlyList<BranchDto> _branches = [];
    private IReadOnlyList<ProductDto> _products = [];
    private IReadOnlyList<ProductAttributeDto> _attributes = [];
    private IReadOnlyList<CustomerDto> _customers = [];
    private Dictionary<long, decimal> _stockByVariant = new();
    private HashSet<string> _permissions = [];
    private MudTextField<string> _searchField = null!;

    private long? _branchId;
    private string _searchTerm = string.Empty;
    private readonly List<CartLine> _cart = [];

    private long? _customerId;
    private bool _showQuickAddCustomer;
    private bool _isSavingQuickCustomer;
    private string _qacName = string.Empty;
    private string? _qacPhone;
    private string? _qacEmail;
    private CustomerCreditSummaryDto? _customerCreditSummary;

    private string _paymentMethod = "Cash";
    private DateTime? _dueDate = DateTime.Today.AddDays(30);
    private string _paymentTerms = "Net 30";
    private decimal _orderDiscountAmount;
    private decimal _amountPaid;
    private bool _amountPaidTouched;
    private string? _notes;
    private bool _isCheckingOut;
    private SalesOrderDto? _lastCompletedOrder;
    private CashRegisterSessionDto? _currentSession;

    private bool _showCreditOverrideConfirm;
    private string _creditOverrideMessage = string.Empty;

    private bool _showQuickAddExpense;
    private bool _isSavingExpense;
    private List<string> _categoryOptions = DefaultExpenseCategories.ToList();
    private bool _showAddExpenseCategory;
    private string? _newExpenseCategoryName;
    private decimal _expAmount;
    private string _expCategory = "Other";
    private string? _expDescription;
    private bool _expPaidFromCash = true;

    private bool _canUse => _permissions.Contains("sales.pos.create");
    private bool _canOperateRegister => _permissions.Contains("finance.cashregister.operate");
    private bool _canRecordExpense => _permissions.Contains("finance.expenses.edit");
    private bool _canOverrideCreditLimit => _permissions.Contains("sales.credit.override_limit");

    private bool IsCreditSale => _paymentMethod is "Credit" or "Split";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _permissions = state.User.FindAll("permission").Select(c => c.Value).ToHashSet();

        if (!_canUse)
            return;

        var branchesResult = await ApiClient.GetBranchesAsync(includeInactive: false);
        if (branchesResult.Success && branchesResult.Data is not null)
            _branches = branchesResult.Data;

        var productsResult = await ApiClient.GetProductsAsync(1, BulkFetchLimit);
        if (productsResult.Success && productsResult.Data is not null)
            _products = productsResult.Data.Data.Where(p => p.IsActive && !p.NotForSelling).ToList();

        var attributesResult = await ApiClient.GetProductAttributesAsync();
        if (attributesResult.Success && attributesResult.Data is not null)
            _attributes = attributesResult.Data;

        await LoadCustomersAsync();

        if (_canRecordExpense)
            await LoadExpenseCategoriesAsync();

        var branchClaim = state.User.FindFirst("branch_id")?.Value;
        _branchId = long.TryParse(branchClaim, out var claimedBranchId) && _branches.Any(b => b.Id == claimedBranchId)
            ? claimedBranchId
            : _branches.FirstOrDefault()?.Id;

        await LoadStockAsync();
        await LoadCashRegisterSessionAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _canUse)
            await _searchField.FocusAsync();
    }

    /// <summary>
    /// Builds a small, self-contained HTML snippet for the receipt (plain tags +
    /// inline styles, no MudBlazor classes) and hands it to retailSphereReceipt.print,
    /// which opens it in a brand-new browser window/tab and calls that window's own
    /// print() — this is what makes the OS/browser print dialog actually appear as a
    /// real popup (choosing "Save as PDF" there is how "Download PDF" is satisfied),
    /// instead of trying to print the current in-page panel.
    /// </summary>
    private async Task PrintReceiptAsync()
    {
        if (_lastCompletedOrder is null)
            return;

        var html = BuildReceiptHtml(_lastCompletedOrder);
        await JsRuntime.InvokeVoidAsync("retailSphereReceipt.print", html);
    }

    private static string BuildReceiptHtml(SalesOrderDto order)
    {
        string Encode(string? value) => System.Net.WebUtility.HtmlEncode(value ?? string.Empty);

        string Row(string label, string value, bool bold = false)
        {
            var content = $"<span>{Encode(label)}</span><span>{Encode(value)}</span>";
            if (bold)
                content = $"<strong>{content}</strong>";
            return $"<div class=\"rs-row\">{content}</div>";
        }

        var linesHtml = string.Join(string.Empty, order.Lines.Select(line =>
            Row($"{line.DescriptionSnapshot} x{line.Quantity:0.###}", line.LineTotal.ToString("0.00"))));

        var discountHtml = order.OrderDiscountAmount > 0
            ? Row("Discount", $"-{order.OrderDiscountAmount:0.00}")
            : string.Empty;

        var outstandingHtml = order.OutstandingBalance > 0
            ? Row("Outstanding", order.OutstandingBalance.ToString("0.00"))
            : string.Empty;

        return
            "<div class=\"rs-receipt\">" +
            $"<div class=\"rs-center\"><strong>{Encode(order.BranchName ?? "RetailSphere")}</strong><br/>" +
            $"Receipt — {Encode(order.OrderNumber)}<br/>" +
            $"{order.OrderDate.ToLocalTime():g}</div>" +
            "<hr/>" +
            $"<div>Cashier: {Encode(order.CashierName ?? "—")}</div>" +
            $"<div>Customer: {Encode(order.CustomerName ?? "Walk-in")}</div>" +
            "<hr/>" +
            linesHtml +
            "<hr/>" +
            Row("Subtotal", order.SubtotalAmount.ToString("0.00")) +
            Row("Tax", order.TaxAmount.ToString("0.00")) +
            discountHtml +
            Row("Total", order.TotalAmount.ToString("0.00"), bold: true) +
            Row($"Paid ({order.PaymentMethod})", order.AmountPaid.ToString("0.00")) +
            outstandingHtml +
            Row("Change due", order.ChangeDue.ToString("0.00")) +
            "<hr/>" +
            "<div class=\"rs-center\">Thank you for your purchase!</div>" +
            "</div>";
    }

    private async Task ShareReceiptAsync()
    {
        if (_lastCompletedOrder is null)
            return;

        var lines = string.Join("\n", _lastCompletedOrder.Lines.Select(l => $"{l.DescriptionSnapshot} x{l.Quantity:0.###}  {l.LineTotal:0.00}"));
        var summary = $"Receipt {_lastCompletedOrder.OrderNumber}\n{_lastCompletedOrder.BranchName}\n\n{lines}\n\nTotal: {_lastCompletedOrder.TotalAmount:0.00}\nPaid: {_lastCompletedOrder.AmountPaid:0.00}\nChange due: {_lastCompletedOrder.ChangeDue:0.00}";

        var outcome = await JsRuntime.InvokeAsync<string>("retailSphereReceipt.share", $"Receipt {_lastCompletedOrder.OrderNumber}", summary);

        Snackbar.Add(outcome switch
        {
            "shared" => "Receipt shared.",
            "copied" => "Sharing isn't available — receipt copied to clipboard instead.",
            "cancelled" => "Share cancelled.",
            _ => "Sharing isn't supported on this browser.",
        }, outcome is "shared" or "copied" ? Severity.Success : Severity.Info);
    }

    private async Task LoadCashRegisterSessionAsync()
    {
        _currentSession = null;
        if (_branchId is null)
            return;

        var result = await ApiClient.GetCurrentCashRegisterSessionAsync(_branchId.Value);
        if (result.Success)
            _currentSession = result.Data;
    }

    private async Task LoadCustomersAsync()
    {
        var customersResult = await ApiClient.GetCustomersAsync(includeInactive: false);
        if (customersResult.Success && customersResult.Data is not null)
            _customers = customersResult.Data;
    }

    /// <summary>Suggested defaults merged with every distinct category already recorded — see GetExpenseCategoriesQueryHandler. Category itself stays freeform on the server, so a brand-new name typed via AddNewExpenseCategory becomes real the moment an expense is saved with it.</summary>
    private async Task LoadExpenseCategoriesAsync()
    {
        var result = await ApiClient.GetExpenseCategoriesAsync();
        if (result.Success && result.Data is not null && result.Data.Count > 0)
            _categoryOptions = result.Data.ToList();
    }

    private void AddNewExpenseCategory()
    {
        var trimmed = _newExpenseCategoryName?.Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            Snackbar.Add("Enter a category name.", Severity.Warning);
            return;
        }

        if (!_categoryOptions.Any(c => string.Equals(c, trimmed, StringComparison.OrdinalIgnoreCase)))
        {
            _categoryOptions.Add(trimmed);
            _categoryOptions = _categoryOptions.OrderBy(c => c, StringComparer.OrdinalIgnoreCase).ToList();
        }

        _expCategory = trimmed;
        _newExpenseCategoryName = null;
        _showAddExpenseCategory = false;
    }

    private async Task LoadStockAsync()
    {
        _stockByVariant = new Dictionary<long, decimal>();
        if (_branchId is null)
            return;

        var stockResult = await ApiClient.GetStockItemsAsync(1, BulkFetchLimit, _branchId.Value);
        if (stockResult.Success && stockResult.Data is not null)
            _stockByVariant = stockResult.Data.Data.ToDictionary(s => s.ProductVariantId, s => s.QuantityOnHand);
    }

    private async Task OnBranchChangedAsync(long? branchId)
    {
        _branchId = branchId;
        await LoadStockAsync();
        await LoadCashRegisterSessionAsync();
    }

    /// <summary>Fetches the Customer Credit Summary the moment a customer is selected at checkout (per the POS Integration requirements) — outstanding balance, available credit, unpaid invoice count, last payment date, total overdue.</summary>
    private async Task OnCustomerChangedAsync(long? customerId)
    {
        _customerId = customerId;
        _customerCreditSummary = null;
        _showCreditOverrideConfirm = false;

        if (!customerId.HasValue)
            return;

        var result = await ApiClient.GetCustomerCreditSummaryAsync(customerId.Value);
        if (result.Success && result.Data is not null)
            _customerCreditSummary = result.Data;
    }

    private void OnPaymentMethodChanged(string value)
    {
        _paymentMethod = value;
        _showCreditOverrideConfirm = false;

        // A cash/card/etc. sale always needs to be paid in full — re-sync Amount Paid
        // to the total the same way a fresh cart does, unless the cashier already
        // deliberately typed a different value in.
        if (!IsCreditSale)
            SyncAmountPaid();
    }

    private void OnSearchChanged(string value) => _searchTerm = value;

    private decimal GetAvailableQty(long variantId) => _stockByVariant.TryGetValue(variantId, out var qty) ? qty : 0;

    private List<(ProductDto Product, ProductVariantDto Variant)> GetSearchResults()
    {
        if (string.IsNullOrWhiteSpace(_searchTerm))
            return [];

        var term = _searchTerm.Trim();

        return _products
            .SelectMany(p => p.Variants.Where(v => v.IsActive).Select(v => (Product: p, Variant: v)))
            .Where(x =>
                x.Product.Name.Contains(term, StringComparison.InvariantCultureIgnoreCase)
                || x.Variant.Sku.Contains(term, StringComparison.InvariantCultureIgnoreCase)
                || (x.Variant.Barcode?.Contains(term, StringComparison.InvariantCultureIgnoreCase) ?? false))
            .Take(20)
            .ToList();
    }

    /// <summary>Joins a variant's AttributeValueIds back to their owning attribute's Name/Value — mirrors Products.razor's GetVariantAttributeLabel.</summary>
    private string GetAttributeLabel(ProductVariantDto variant)
    {
        if (variant.AttributeValueIds.Count == 0)
            return "—";

        var parts = new List<string>();
        foreach (var attribute in _attributes)
        {
            var matched = attribute.Values
                .Where(v => variant.AttributeValueIds.Contains(v.Id))
                .Select(v => v.Value)
                .ToList();

            if (matched.Count > 0)
                parts.Add($"{attribute.Name}: {string.Join(", ", matched)}");
        }

        return parts.Count > 0 ? string.Join(" · ", parts) : "—";
    }

    private async Task AddToCart(ProductDto product, ProductVariantDto variant)
    {
        var existing = _cart.FirstOrDefault(c => c.ProductVariantId == variant.Id);
        if (existing is not null)
        {
            existing.Quantity += 1;
            SyncAmountPaid();
        }
        else
        {
            var attributeLabel = GetAttributeLabel(variant);
            var description = attributeLabel == "—" ? product.Name : $"{product.Name} — {attributeLabel}";

            _cart.Add(new CartLine
            {
                ProductId = product.Id,
                ProductVariantId = variant.Id,
                Sku = variant.Sku,
                Description = description,
                UnitPrice = variant.Price,
                TaxRate = variant.TaxRate,
                TaxType = variant.TaxType,
                Quantity = 1,
                DiscountAmount = 0,
            });
            SyncAmountPaid();
        }

        // Clear and refocus the search box right after adding — the cashier can keep
        // scanning/typing the next item without reaching for the mouse, matching a
        // typical barcode-scanner-driven checkout flow.
        _searchTerm = string.Empty;
        await _searchField.FocusAsync();
    }

    /// <summary>
    /// Barcode scanners send Enter after the code — if the current search text
    /// resolves to exactly one item, Enter adds it immediately instead of requiring
    /// a click on "Add", so a scan-driven checkout never needs the mouse.
    /// </summary>
    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter")
            return;

        var results = GetSearchResults();
        if (results.Count == 1)
            await AddToCart(results[0].Product, results[0].Variant);
    }

    private void SetCartQuantity(CartLine line, decimal value)
    {
        line.Quantity = value < 0 ? 0 : value;
        SyncAmountPaid();
    }

    private void SetCartDiscount(CartLine line, decimal value)
    {
        line.DiscountAmount = value < 0 ? 0 : value;
        SyncAmountPaid();
    }

    private void RemoveFromCart(CartLine line)
    {
        _cart.Remove(line);
        SyncAmountPaid();
    }

    private void OnOrderDiscountChanged(decimal value)
    {
        _orderDiscountAmount = value < 0 ? 0 : value;
        SyncAmountPaid();
    }

    private void OnAmountPaidChanged(decimal value)
    {
        _amountPaid = value < 0 ? 0 : value;
        _amountPaidTouched = true;
        _showCreditOverrideConfirm = false;
    }

    /// <summary>
    /// Keeps Amount Paid defaulted to the current total as the cart changes, until
    /// the cashier types their own value into it (see OnAmountPaidChanged) — matches
    /// "pre-filled with the total by default, editable if the customer pays
    /// something else." Reset alongside the rest of the checkout state in
    /// CheckoutAsync so the next sale starts fresh.
    /// </summary>
    private void SyncAmountPaid()
    {
        if (!_amountPaidTouched)
            _amountPaid = GetTotal();
    }

    /// <summary>Client-side preview only — the server independently recomputes tax/totals from the catalog at checkout (see CreateSalesOrderCommandHandler).</summary>
    private decimal GetLineTaxAmount(CartLine line) => line.TaxType == "Inclusive"
        ? (line.UnitPrice * line.Quantity) - (line.UnitPrice * line.Quantity / (1 + line.TaxRate / 100m))
        : line.UnitPrice * line.Quantity * line.TaxRate / 100m;

    private decimal GetLineTotal(CartLine line) => line.TaxType == "Inclusive"
        ? (line.UnitPrice * line.Quantity) - line.DiscountAmount
        : (line.UnitPrice * line.Quantity) + GetLineTaxAmount(line) - line.DiscountAmount;

    private decimal GetSubtotal() => _cart.Sum(l => l.UnitPrice * l.Quantity);

    private decimal GetTaxTotal() => _cart.Sum(GetLineTaxAmount);

    private decimal GetTotal() => Math.Max(0, _cart.Sum(GetLineTotal) - _orderDiscountAmount);

    private decimal GetChangeDue() => Math.Max(0, _amountPaid - GetTotal());

    private async Task CreateQuickCustomerAsync()
    {
        if (string.IsNullOrWhiteSpace(_qacName))
        {
            Snackbar.Add("Customer name is required.", Severity.Warning);
            return;
        }

        _isSavingQuickCustomer = true;

        var result = await ApiClient.CreateCustomerAsync(new CreateCustomerRequest
        {
            Name = _qacName,
            Phone = _qacPhone,
            Email = _qacEmail,
        });

        if (result.Success && result.Data is not null)
        {
            await LoadCustomersAsync();
            await OnCustomerChangedAsync(result.Data.Id);
            _showQuickAddCustomer = false;
            _qacName = string.Empty;
            _qacPhone = null;
            _qacEmail = null;
            Snackbar.Add("Customer added.", Severity.Success);
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to add customer.", Severity.Error);
        }

        _isSavingQuickCustomer = false;
    }

    private async Task SaveExpenseAsync()
    {
        if (_branchId is null)
        {
            Snackbar.Add("Select a branch first.", Severity.Warning);
            return;
        }

        if (_expAmount <= 0)
        {
            Snackbar.Add("Amount must be greater than zero.", Severity.Warning);
            return;
        }

        _isSavingExpense = true;

        var result = await ApiClient.CreateExpenseAsync(new CreateExpenseRequest
        {
            BranchId = _branchId.Value,
            ExpenseDate = DateTime.Today,
            Amount = _expAmount,
            Category = _expCategory,
            Description = _expDescription,
            PaidFromCash = _expPaidFromCash,
        });

        if (result.Success)
        {
            Snackbar.Add("Expense recorded.", Severity.Success);
            _showQuickAddExpense = false;
            _expAmount = 0;
            _expCategory = "Other";
            _expDescription = null;
            _expPaidFromCash = true;
            _showAddExpenseCategory = false;
            _newExpenseCategoryName = null;

            // Recorded expenses paid from cash affect the cash register's expected
            // balance — refresh the banner so "Current Cash Balance" stays accurate.
            await LoadCashRegisterSessionAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to record expense.", Severity.Error);
        }

        _isSavingExpense = false;
    }

    /// <summary>
    /// A walk-in (no customer selected) sale must always be paid in full — same
    /// invariant SalesOrder.SetAmountPaid enforces server-side. A customer sale can
    /// be Credit (AmountPaid = 0) or Split (0 &lt; AmountPaid &lt; Total); the server
    /// is still the source of truth, this is just an early, friendlier check.
    /// On a SalesOrder.CreditLimitExceeded error, shows an inline confirmation —
    /// resubmitting with overrideCreditLimit: true is only offered to users holding
    /// sales.credit.override_limit (see CreateSalesOrderCommandHandler).
    /// </summary>
    private async Task CheckoutAsync(bool overrideCreditLimit)
    {
        if (_branchId is null)
        {
            Snackbar.Add("Select a branch.", Severity.Warning);
            return;
        }

        if (_cart.Count == 0)
        {
            Snackbar.Add("Add at least one item to the cart.", Severity.Warning);
            return;
        }

        if (_customerId is null && _amountPaid < GetTotal())
        {
            Snackbar.Add("A walk-in sale must be paid in full — select a customer to allow a credit or split payment.", Severity.Warning);
            return;
        }

        _isCheckingOut = true;
        _showCreditOverrideConfirm = false;

        var request = new CreateSalesOrderRequest
        {
            BranchId = _branchId.Value,
            CustomerId = _customerId,
            PaymentMethod = _paymentMethod,
            OrderDiscountAmount = _orderDiscountAmount,
            AmountPaid = _amountPaid,
            Notes = _notes,
            PaymentTerms = IsCreditSale ? _paymentTerms : null,
            DueDate = IsCreditSale ? _dueDate : null,
            OverrideCreditLimit = overrideCreditLimit,
            Lines = _cart.Select(c => new CreateSalesOrderLineRequest
            {
                ProductId = c.ProductId,
                ProductVariantId = c.ProductVariantId,
                Quantity = c.Quantity,
                DiscountAmount = c.DiscountAmount,
            }).ToList(),
        };

        var result = await ApiClient.CreateSalesOrderAsync(request);

        if (result.Success && result.Data is not null)
        {
            Snackbar.Add($"Sale completed — {result.Data.OrderNumber}.", Severity.Success);
            _lastCompletedOrder = result.Data;
            _cart.Clear();
            _customerId = null;
            _customerCreditSummary = null;
            _orderDiscountAmount = 0;
            _amountPaid = 0;
            _amountPaidTouched = false;
            _notes = null;
            _paymentMethod = "Cash";
            _dueDate = DateTime.Today.AddDays(30);
            _paymentTerms = "Net 30";
            await LoadStockAsync();
            await LoadCashRegisterSessionAsync();
        }
        else if (result.Error?.Code == "SalesOrder.CreditLimitExceeded")
        {
            _creditOverrideMessage = result.Error.Message;
            _showCreditOverrideConfirm = true;
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Checkout failed.", Severity.Error);
        }

        _isCheckingOut = false;
    }
}
