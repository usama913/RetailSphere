@page "/sales/customer-payments"
@using RetailSphere.Contracts.Admin
@using RetailSphere.Contracts.Customers
@using RetailSphere.Contracts.Sales
@attribute [Authorize]
@inject IApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject IJSRuntime JsRuntime

<PageTitle>Customer Payments - RetailSphere</PageTitle>

@if (!_canView)
{
    <MudAlert Severity="Severity.Warning">You don't have permission to view customer payments.</MudAlert>
}
else
{

<MudText Typo="Typo.h5" Class="mb-1">Customer Payments</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Find a customer, apply a payment across one or more outstanding invoices, and review their payment history.
</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" md="4">
        <MudSelect T="long?" Value="_selectedCustomerId" ValueChanged="OnCustomerChangedAsync" Label="Customer" Variant="Variant.Outlined">
            <MudSelectItem T="long?" Value="@((long?)null)">Select a customer…</MudSelectItem>
            @foreach (var customer in _customers)
            {
                <MudSelectItem T="long?" Value="@((long?)customer.Id)">@customer.Name</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
</MudGrid>

@if (_selectedCustomerId is null)
{
    <MudAlert Severity="Severity.Info">Select a customer to begin.</MudAlert>
}
else if (_isLoadingCustomer)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    @if (_creditSummary is not null)
    {
        <MudPaper Class="pa-4 mb-4" Elevation="1">
            <MudGrid>
                <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Credit limit</MudText><MudText Typo="Typo.h6">@(_creditSummary.CreditLimit.HasValue ? _creditSummary.CreditLimit.Value.ToString("0.00") : "Unlimited")</MudText></MudItem>
                <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Outstanding balance</MudText><MudText Typo="Typo.h6">@_creditSummary.CurrentOutstandingBalance.ToString("0.00")</MudText></MudItem>
                <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Available credit</MudText><MudText Typo="Typo.h6">@(_creditSummary.AvailableCredit.HasValue ? _creditSummary.AvailableCredit.Value.ToString("0.00") : "—")</MudText></MudItem>
                <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Overdue amount</MudText><MudText Typo="Typo.h6" Style="@(_creditSummary.TotalOverdueAmount > 0 ? "color: var(--mud-palette-error);" : null)">@_creditSummary.TotalOverdueAmount.ToString("0.00")</MudText></MudItem>
                <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Unpaid invoices</MudText><MudText Typo="Typo.body1">@_creditSummary.UnpaidInvoiceCount</MudText></MudItem>
                <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Last payment</MudText><MudText Typo="Typo.body1">@(_creditSummary.LastPaymentDate.HasValue ? _creditSummary.LastPaymentDate.Value.ToString("yyyy-MM-dd") : "—")</MudText></MudItem>
            </MudGrid>
            @if (_creditSummary.IsOverCreditLimit)
            {
                <MudAlert Severity="Severity.Warning" Class="mt-3">This customer is currently over their credit limit.</MudAlert>
            }
        </MudPaper>
    }

    <MudText Typo="Typo.subtitle1" Class="mb-2">Outstanding invoices</MudText>
    @if (_outstandingOrders.Count == 0)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4">No outstanding invoices for this customer.</MudAlert>
    }
    else
    {
        <MudTable Items="@_outstandingOrders" Hover="true" Dense="true" Class="mb-4">
            <HeaderContent>
                <MudTh>Apply</MudTh>
                <MudTh>Order #</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Due date</MudTh>
                <MudTh>Total</MudTh>
                <MudTh>Outstanding</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Amount to apply</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Apply">
                    <MudCheckBox T="bool" Value="@_selectedOrderIds.Contains(context.Id)" ValueChanged="@((bool v) => ToggleOrderSelection(context, v))" />
                </MudTd>
                <MudTd DataLabel="Order #">@context.OrderNumber</MudTd>
                <MudTd DataLabel="Date">@context.OrderDate.ToString("yyyy-MM-dd")</MudTd>
                <MudTd DataLabel="Due date">@(context.DueDate.HasValue ? context.DueDate.Value.ToString("yyyy-MM-dd") : "—")</MudTd>
                <MudTd DataLabel="Total">@context.TotalAmount.ToString("0.00")</MudTd>
                <MudTd DataLabel="Outstanding">@context.OutstandingBalance.ToString("0.00")</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@(context.PaymentStatus == "Overdue" ? Color.Error : Color.Default)">@context.PaymentStatus</MudChip>
                </MudTd>
                <MudTd DataLabel="Amount to apply">
                    @if (_selectedOrderIds.Contains(context.Id))
                    {
                        <MudNumericField T="decimal" Value="@GetAllocationAmount(context.Id)" ValueChanged="@((decimal v) => SetAllocationAmount(context.Id, v))" Format="0.00" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    @if (_canRecord)
    {
        <MudPaper Class="pa-4 mb-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-3">Record a payment</MudText>
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="long?" @bind-Value="_formBranchId" Label="Branch" Variant="Variant.Outlined" Required="true">
                        @foreach (var branch in _branches)
                        {
                            <MudSelectItem T="long?" Value="@((long?)branch.Id)">@branch.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField @bind-Value="_formAmount" Label="Payment amount" Variant="Variant.Outlined" Format="0.00" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker @bind-Date="_formPaymentDate" Label="Payment date" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string" @bind-Value="_formMethod" Label="Method" Variant="Variant.Outlined">
                        <MudSelectItem T="string" Value='@("Cash")'>Cash</MudSelectItem>
                        <MudSelectItem T="string" Value='@("Card")'>Card</MudSelectItem>
                        <MudSelectItem T="string" Value='@("Bank Transfer")'>Bank Transfer</MudSelectItem>
                        <MudSelectItem T="string" Value='@("Mobile Payment")'>Mobile Payment</MudSelectItem>
                        <MudSelectItem T="string" Value='@("Cheque")'>Cheque</MudSelectItem>
                        <MudSelectItem T="string" Value='@("Other")'>Other</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_formReference" Label="Reference #" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_formNotes" Label="Notes" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            <MudText Typo="Typo.body2" Class="mt-2">Allocated so far: @TotalAllocated().ToString("0.00") of @_formAmount.ToString("0.00")</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SubmitPaymentAsync" Disabled="@_isSaving">
                Record Payment
            </MudButton>
        </MudPaper>
    }

    <MudText Typo="Typo.subtitle1" Class="mb-2">Payment history</MudText>
    <MudTable Items="@_payments" Hover="true" Dense="true" Loading="@_isLoadingPayments">
        <HeaderContent>
            <MudTh>Date</MudTh>
            <MudTh>Amount</MudTh>
            <MudTh>Method</MudTh>
            <MudTh>Reference</MudTh>
            <MudTh>Allocated</MudTh>
            <MudTh>Unallocated</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Date">@context.PaymentDate.ToString("yyyy-MM-dd")</MudTd>
            <MudTd DataLabel="Amount">@context.Amount.ToString("0.00")</MudTd>
            <MudTd DataLabel="Method">@context.PaymentMethod</MudTd>
            <MudTd DataLabel="Reference">@(context.ReferenceNumber ?? "—")</MudTd>
            <MudTd DataLabel="Allocated">@context.AllocatedAmount.ToString("0.00")</MudTd>
            <MudTd DataLabel="Unallocated">@context.UnallocatedAmount.ToString("0.00")</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@(context.IsReversed ? Color.Default : Color.Success)">@(context.IsReversed ? "Reversed" : "Active")</MudChip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Print" Size="Size.Small" Title="Print receipt" OnClick="@(() => PrintReceiptAsync(context))" />
                @if (_canEdit && !context.IsReversed)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Undo" Size="Size.Small" Title="Reverse" OnClick="@(() => ReversePaymentAsync(context.Id))" />
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

}

@code {
    private IReadOnlyList<CustomerDto> _customers = [];
    private IReadOnlyList<BranchDto> _branches = [];
    private HashSet<string> _permissions = [];

    private long? _selectedCustomerId;
    private bool _isLoadingCustomer;
    private CustomerCreditSummaryDto? _creditSummary;
    private List<SalesOrderDto> _outstandingOrders = [];
    private IReadOnlyList<CustomerPaymentDto> _payments = [];
    private bool _isLoadingPayments;

    private readonly HashSet<long> _selectedOrderIds = [];
    private readonly Dictionary<long, decimal> _allocationAmounts = [];

    private long? _formBranchId;
    private decimal _formAmount;
    private DateTime? _formPaymentDate = DateTime.Today;
    private string _formMethod = "Cash";
    private string? _formReference;
    private string? _formNotes;
    private bool _isSaving;

    private bool _canView => _permissions.Contains("customers.payments.view");
    private bool _canRecord => _permissions.Contains("customers.payments.record");
    private bool _canEdit => _permissions.Contains("customers.payments.edit");

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _permissions = state.User.FindAll("permission").Select(c => c.Value).ToHashSet();

        if (!_canView)
            return;

        var customersResult = await ApiClient.GetCustomersAsync(includeInactive: true);
        if (customersResult.Success && customersResult.Data is not null)
            _customers = customersResult.Data;

        var branchesResult = await ApiClient.GetBranchesAsync(includeInactive: true);
        if (branchesResult.Success && branchesResult.Data is not null)
            _branches = branchesResult.Data;
    }

    private async Task OnCustomerChangedAsync(long? customerId)
    {
        _selectedCustomerId = customerId;
        _creditSummary = null;
        _outstandingOrders = [];
        _payments = [];
        _selectedOrderIds.Clear();
        _allocationAmounts.Clear();

        if (!customerId.HasValue)
            return;

        _isLoadingCustomer = true;

        var summaryResult = await ApiClient.GetCustomerCreditSummaryAsync(customerId.Value);
        if (summaryResult.Success && summaryResult.Data is not null)
            _creditSummary = summaryResult.Data;

        var ordersResult = await ApiClient.GetSalesOrdersAsync(1, 200, null, null, customerId.Value);
        if (ordersResult.Success && ordersResult.Data is not null)
        {
            _outstandingOrders = ordersResult.Data.Data
                .Where(o => o.Status != "Cancelled" && o.OutstandingBalance > 0)
                .OrderBy(o => o.DueDate ?? o.OrderDate)
                .ToList();
        }

        await LoadPaymentsAsync();

        _isLoadingCustomer = false;
    }

    private async Task LoadPaymentsAsync()
    {
        if (!_selectedCustomerId.HasValue)
            return;

        _isLoadingPayments = true;
        var result = await ApiClient.GetCustomerPaymentsAsync(1, 100, _selectedCustomerId.Value);
        if (result.Success && result.Data is not null)
        {
            _payments = result.Data.Data;
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to load payment history.", Severity.Error);
        }
        _isLoadingPayments = false;
    }

    private void ToggleOrderSelection(SalesOrderDto order, bool selected)
    {
        if (selected)
        {
            _selectedOrderIds.Add(order.Id);
            _allocationAmounts[order.Id] = order.OutstandingBalance;
        }
        else
        {
            _selectedOrderIds.Remove(order.Id);
            _allocationAmounts.Remove(order.Id);
        }
    }

    private decimal GetAllocationAmount(long orderId) => _allocationAmounts.TryGetValue(orderId, out var amount) ? amount : 0;

    private void SetAllocationAmount(long orderId, decimal amount) => _allocationAmounts[orderId] = amount;

    private decimal TotalAllocated() => _allocationAmounts.Values.Sum();

    private async Task SubmitPaymentAsync()
    {
        if (!_selectedCustomerId.HasValue || !_formBranchId.HasValue)
        {
            Snackbar.Add("Select a branch before recording a payment.", Severity.Warning);
            return;
        }

        if (_formAmount <= 0)
        {
            Snackbar.Add("Payment amount must be greater than zero.", Severity.Warning);
            return;
        }

        if (TotalAllocated() > _formAmount)
        {
            Snackbar.Add("Allocated amount cannot exceed the payment amount.", Severity.Warning);
            return;
        }

        _isSaving = true;

        var allocations = _selectedOrderIds
            .Where(id => GetAllocationAmount(id) > 0)
            .Select(id => new CustomerPaymentAllocationRequest { SalesOrderId = id, Amount = GetAllocationAmount(id) })
            .ToList();

        var result = await ApiClient.RecordCustomerPaymentAsync(new RecordCustomerPaymentRequest
        {
            CustomerId = _selectedCustomerId.Value,
            BranchId = _formBranchId.Value,
            PaymentDate = _formPaymentDate ?? DateTime.Today,
            Amount = _formAmount,
            PaymentMethod = _formMethod,
            ReferenceNumber = _formReference,
            Notes = _formNotes,
            Allocations = allocations,
        });

        if (result.Success)
        {
            Snackbar.Add("Payment recorded.", Severity.Success);
            _formAmount = 0;
            _formReference = null;
            _formNotes = null;
            _selectedOrderIds.Clear();
            _allocationAmounts.Clear();
            await OnCustomerChangedAsync(_selectedCustomerId);
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to record payment.", Severity.Error);
        }

        _isSaving = false;
    }

    private async Task ReversePaymentAsync(long paymentId)
    {
        var result = await ApiClient.ReverseCustomerPaymentAsync(paymentId, new ReverseCustomerPaymentRequest { Reason = "Reversed from Customer Payments screen" });
        if (result.Success)
        {
            Snackbar.Add("Payment reversed.", Severity.Success);
            await OnCustomerChangedAsync(_selectedCustomerId);
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to reverse payment.", Severity.Error);
        }
    }

    private async Task PrintReceiptAsync(CustomerPaymentDto payment)
    {
        var customerName = _customers.FirstOrDefault(c => c.Id == _selectedCustomerId)?.Name ?? "Customer";
        var html = BuildReceiptHtml(customerName, payment);
        await JsRuntime.InvokeVoidAsync("retailSphereReceipt.print", html);
    }

    /// <summary>
    /// Built via plain concatenation with \"-escaped regular interpolated strings
    /// (never a multi-line verbatim $@"..." literal) — a raw HTML-looking verbatim
    /// string inside a Razor @code block can confuse the Razor tokenizer's tag/brace
    /// matching (seen as RZ9981/RZ1026/RZ1000 "unterminated string" / mismatched
    /// "div" errors), even though the equivalent plain C# is completely valid.
    /// Mirrors PointOfSale.razor's BuildReceiptHtml for the same reason.
    /// </summary>
    private static string BuildReceiptHtml(string customerName, CustomerPaymentDto payment)
    {
        string Encode(string? value) => System.Net.WebUtility.HtmlEncode(value ?? string.Empty);

        string Row(string label, string value) =>
            $"<div class=\"rs-row\"><span>{Encode(label)}</span><span>{Encode(value)}</span></div>";

        return
            "<div class=\"rs-receipt\">" +
            $"<div class=\"rs-center\">{Encode(customerName)}</div>" +
            "<hr/>" +
            Row("Date", payment.PaymentDate.ToString("yyyy-MM-dd")) +
            Row("Method", payment.PaymentMethod) +
            Row("Reference", payment.ReferenceNumber ?? "-") +
            "<hr/>" +
            Row("Amount", payment.Amount.ToString("0.00")) +
            Row("Applied", payment.AllocatedAmount.ToString("0.00")) +
            Row("Unapplied", payment.UnallocatedAmount.ToString("0.00")) +
            "</div>";
    }
}
