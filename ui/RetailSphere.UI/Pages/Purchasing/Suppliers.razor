@page "/purchasing/suppliers"
@using RetailSphere.Contracts.Purchasing
@attribute [Authorize]
@inject IApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Suppliers - RetailSphere</PageTitle>

@if (!_canView)
{
    <MudAlert Severity="Severity.Warning">You don't have permission to view suppliers.</MudAlert>
}
else
{

<PageHeader Title="Suppliers" Subtitle="Vendors you purchase stock from." Breadcrumbs="_breadcrumbs">
    <Actions>
        @if (_canEdit)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="ShowCreateForm">
                New Supplier
            </MudButton>
        }
    </Actions>
</PageHeader>

<MudTable Items="@_suppliers" Hover="true" Dense="true" Loading="@_isLoading">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Contact person</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Phone</MudTh>
        <MudTh>Credit limit</MudTh>
        <MudTh>Payment terms</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Contact person">@(context.ContactPerson ?? "—")</MudTd>
        <MudTd DataLabel="Email">@(context.Email ?? "—")</MudTd>
        <MudTd DataLabel="Phone">@(context.Phone ?? "—")</MudTd>
        <MudTd DataLabel="Credit limit">@(context.CreditLimit.HasValue ? context.CreditLimit.Value.ToString("0.00") : "Unlimited")</MudTd>
        <MudTd DataLabel="Payment terms">@context.PaymentTerms</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                @(context.IsActive ? "Active" : "Inactive")
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Actions">
            @if (_canEdit)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => ShowEditForm(context))" />
                @if (context.IsActive)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PauseCircle" Size="Size.Small" OnClick="@(() => DeactivateAsync(context.Id))" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" OnClick="@(() => ActivateAsync(context.Id))" />
                }
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => ConfirmDeleteAsync(context))" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <EmptyState Icon="@Icons.Material.Filled.Business" Title="No suppliers yet"
                    Description="Add your first supplier to start recording purchases and invoices from them." />
    </NoRecordsContent>
    <LoadingContent>
        <TableSkeleton Rows="5" />
    </LoadingContent>
</MudTable>

<MudDialog @bind-Visible="_showForm" Options="AppDialogOptions.Medium">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingId is null ? "New Supplier" : "Edit Supplier")</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formName" Label="Name" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formContactPerson" Label="Contact person" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formEmail" Label="Email" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formPhone" Label="Phone" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formAddress" Label="Address" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formTaxNumber" Label="Tax number" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_formCreditLimit" Label="Credit limit (leave blank for unlimited)" Variant="Variant.Outlined" Min="0" Format="0.00" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formPaymentTerms" Label="Payment terms" Variant="Variant.Outlined" Placeholder="Net 30" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelForm">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_isSaving">Save</MudButton>
    </DialogActions>
</MudDialog>

}

@code {
    private static readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", href: "/"),
        new("Purchasing", href: null),
        new("Suppliers", href: null),
    ];

    private IReadOnlyList<SupplierDto> _suppliers = [];
    private HashSet<string> _permissions = [];

    private bool _isLoading = true;
    private bool _isSaving;
    private bool _showForm;
    private long? _editingId;

    private string _formName = string.Empty;
    private string? _formContactPerson;
    private string? _formEmail;
    private string? _formPhone;
    private string? _formAddress;
    private string? _formTaxNumber;
    private decimal? _formCreditLimit;
    private string? _formPaymentTerms;

    private bool _canView => _permissions.Contains("purchasing.suppliers.view");
    private bool _canEdit => _permissions.Contains("purchasing.suppliers.edit");

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _permissions = state.User.FindAll("permission").Select(c => c.Value).ToHashSet();

        if (_canView)
        {
            await LoadAsync();
        }
        else
        {
            _isLoading = false;
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        var result = await ApiClient.GetSuppliersAsync(includeInactive: true);
        if (result.Success && result.Data is not null)
        {
            _suppliers = result.Data;
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to load suppliers.", Severity.Error);
        }
        _isLoading = false;
    }

    private void ShowCreateForm()
    {
        _editingId = null;
        _formName = string.Empty;
        _formContactPerson = null;
        _formEmail = null;
        _formPhone = null;
        _formAddress = null;
        _formTaxNumber = null;
        _formCreditLimit = null;
        _formPaymentTerms = null;
        _showForm = true;
    }

    private void ShowEditForm(SupplierDto supplier)
    {
        _editingId = supplier.Id;
        _formName = supplier.Name;
        _formContactPerson = supplier.ContactPerson;
        _formEmail = supplier.Email;
        _formPhone = supplier.Phone;
        _formAddress = supplier.Address;
        _formTaxNumber = supplier.TaxNumber;
        _formCreditLimit = supplier.CreditLimit;
        _formPaymentTerms = supplier.PaymentTerms;
        _showForm = true;
    }

    private void CancelForm() => _showForm = false;

    /// <summary>
    /// Create/Update carry name/contact/credit fields together in one request (both
    /// CreateSupplierRequest and UpdateSupplierRequest already accept CreditLimit/
    /// PaymentTerms server-side) — no separate "update credit terms" round trip needed
    /// for the common case of editing everything from one dialog.
    /// </summary>
    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            Snackbar.Add("Supplier name is required.", Severity.Warning);
            return;
        }

        _isSaving = true;

        var result = _editingId is null
            ? await ApiClient.CreateSupplierAsync(new CreateSupplierRequest
            {
                Name = _formName,
                ContactPerson = _formContactPerson,
                Email = _formEmail,
                Phone = _formPhone,
                Address = _formAddress,
                TaxNumber = _formTaxNumber,
                CreditLimit = _formCreditLimit,
                PaymentTerms = _formPaymentTerms,
            })
            : await ApiClient.UpdateSupplierAsync(_editingId.Value, new UpdateSupplierRequest
            {
                Name = _formName,
                ContactPerson = _formContactPerson,
                Email = _formEmail,
                Phone = _formPhone,
                Address = _formAddress,
                TaxNumber = _formTaxNumber,
            });

        if (!result.Success)
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to save supplier.", Severity.Error);
            _isSaving = false;
            return;
        }

        // UpdateSupplierRequest (the general edit) doesn't carry credit fields — apply
        // them via the dedicated credit-terms endpoint right after, same "two calls,
        // one dialog" approach Users.razor already uses for roles.
        if (_editingId is not null)
        {
            var creditResult = await ApiClient.UpdateSupplierCreditTermsAsync(_editingId.Value, new UpdateSupplierCreditTermsRequest
            {
                CreditLimit = _formCreditLimit,
                PaymentTerms = _formPaymentTerms,
            });

            if (!creditResult.Success)
            {
                Snackbar.Add(creditResult.Error?.Message ?? "Supplier saved, but credit terms failed to update.", Severity.Warning);
                _isSaving = false;
                _showForm = false;
                await LoadAsync();
                return;
            }
        }

        Snackbar.Add("Supplier saved.", Severity.Success);
        _showForm = false;
        await LoadAsync();
        _isSaving = false;
    }

    private async Task ActivateAsync(long id)
    {
        var result = await ApiClient.ActivateSupplierAsync(id);
        if (result.Success)
        {
            Snackbar.Add("Supplier activated.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to activate supplier.", Severity.Error);
        }
    }

    private async Task DeactivateAsync(long id)
    {
        var result = await ApiClient.DeactivateSupplierAsync(id);
        if (result.Success)
        {
            Snackbar.Add("Supplier deactivated.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to deactivate supplier.", Severity.Error);
        }
    }

    private async Task ConfirmDeleteAsync(SupplierDto supplier)
    {
        if (!await DialogService.ConfirmDeleteAsync($"'{supplier.Name}'"))
            return;

        var result = await ApiClient.DeleteSupplierAsync(supplier.Id);
        if (result.Success)
        {
            Snackbar.Add("Supplier deleted.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to delete supplier.", Severity.Error);
        }
    }
}
