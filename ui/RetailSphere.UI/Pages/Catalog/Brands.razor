@page "/catalog/brands"
@using RetailSphere.Contracts.Catalog
@attribute [Authorize]
@inject IApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Brands - RetailSphere</PageTitle>

@if (!_canView)
{
    <MudAlert Severity="Severity.Warning">You don't have permission to view brands.</MudAlert>
}
else
{

<PageHeader Title="Brands" Subtitle="Brands carried across your catalog." Breadcrumbs="_breadcrumbs">
    <Actions>
        @if (_canEdit)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="ShowCreateForm">
                New Brand
            </MudButton>
        }
    </Actions>
</PageHeader>

<MudTable Items="@_brands" Hover="true" Dense="true" Loading="@_isLoading">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Description">@context.Description</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                @(context.IsActive ? "Active" : "Inactive")
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Actions">
            @if (_canEdit)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => ShowEditForm(context))" />
                @if (context.IsActive)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PauseCircle" Size="Size.Small" OnClick="@(() => DeactivateAsync(context.Id))" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" OnClick="@(() => ActivateAsync(context.Id))" />
                }
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => ConfirmDeleteAsync(context))" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <EmptyState Icon="@Icons.Material.Filled.BrandingWatermark" Title="No brands yet"
                    Description="Add your first brand to start tagging products with it." />
    </NoRecordsContent>
    <LoadingContent>
        <TableSkeleton Rows="5" />
    </LoadingContent>
</MudTable>

<MudDialog @bind-Visible="_showForm" Options="AppDialogOptions.Default">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingId is null ? "New Brand" : "Edit Brand")</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_formName" Label="Name" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_formDescription" Label="Description" Variant="Variant.Outlined" Lines="2" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelForm">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_isSaving">Save</MudButton>
    </DialogActions>
</MudDialog>

}

@code {
    private static readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", href: "/"),
        new("Catalog", href: null),
        new("Brands", href: null),
    ];

    private IReadOnlyList<BrandDto> _brands = [];
    private HashSet<string> _permissions = [];

    private bool _isLoading = true;
    private bool _isSaving;
    private bool _showForm;
    private long? _editingId;

    private string _formName = string.Empty;
    private string? _formDescription;

    private bool _canView => _permissions.Contains("catalog.brands.view");
    private bool _canEdit => _permissions.Contains("catalog.brands.edit");

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _permissions = state.User.FindAll("permission").Select(c => c.Value).ToHashSet();

        if (_canView)
        {
            await LoadAsync();
        }
        else
        {
            _isLoading = false;
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        var result = await ApiClient.GetBrandsAsync(includeInactive: true);
        if (result.Success && result.Data is not null)
        {
            _brands = result.Data;
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to load brands.", Severity.Error);
        }
        _isLoading = false;
    }

    private void ShowCreateForm()
    {
        _editingId = null;
        _formName = string.Empty;
        _formDescription = null;
        _showForm = true;
    }

    private void ShowEditForm(BrandDto brand)
    {
        _editingId = brand.Id;
        _formName = brand.Name;
        _formDescription = brand.Description;
        _showForm = true;
    }

    private void CancelForm() => _showForm = false;

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            Snackbar.Add("Brand name is required.", Severity.Warning);
            return;
        }

        _isSaving = true;

        var result = _editingId is null
            ? await ApiClient.CreateBrandAsync(new CreateBrandRequest { Name = _formName, Description = _formDescription })
            : await ApiClient.UpdateBrandAsync(_editingId.Value, new UpdateBrandRequest { Name = _formName, Description = _formDescription });

        if (result.Success)
        {
            Snackbar.Add("Brand saved.", Severity.Success);
            _showForm = false;
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to save brand.", Severity.Error);
        }

        _isSaving = false;
    }

    private async Task ActivateAsync(long id)
    {
        var result = await ApiClient.ActivateBrandAsync(id);
        if (result.Success)
        {
            Snackbar.Add("Brand activated.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to activate brand.", Severity.Error);
        }
    }

    private async Task DeactivateAsync(long id)
    {
        var result = await ApiClient.DeactivateBrandAsync(id);
        if (result.Success)
        {
            Snackbar.Add("Brand deactivated.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to deactivate brand.", Severity.Error);
        }
    }

    private async Task ConfirmDeleteAsync(BrandDto brand)
    {
        if (!await DialogService.ConfirmDeleteAsync($"'{brand.Name}'"))
            return;

        var result = await ApiClient.DeleteBrandAsync(brand.Id);
        if (result.Success)
        {
            Snackbar.Add("Brand deleted.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to delete brand.", Severity.Error);
        }
    }
}
