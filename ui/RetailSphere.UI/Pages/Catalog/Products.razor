@page "/catalog/products"
@using RetailSphere.Contracts.Admin
@using RetailSphere.Contracts.Catalog
@using RetailSphere.Contracts.Inventory
@attribute [Authorize]
@inject IApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>Products - RetailSphere</PageTitle>

@if (!_canView)
{
    <MudAlert Severity="Severity.Warning">You don't have permission to view products.</MudAlert>
}
else
{

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <div>
        <MudText Typo="Typo.h5">Products</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Product templates and their sellable SKUs.</MudText>
    </div>
    @if (_canEdit)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="ShowCreateForm">
            New Product
        </MudButton>
    }
</MudStack>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" md="3">
        <MudTextField T="string" Value="@_search" ValueChanged="OnSearchChanged" Label="Search by name"
                      Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="300" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudSelect T="long?" Value="_filterCategoryId" ValueChanged="OnFilterCategoryChanged" Label="Category" Variant="Variant.Outlined">
            <MudSelectItem T="long?" Value="@((long?)null)">All categories</MudSelectItem>
            @foreach (var category in _categories)
            {
                <MudSelectItem T="long?" Value="@((long?)category.Id)">@category.Name</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudSelect T="long?" Value="_filterBrandId" ValueChanged="OnFilterBrandChanged" Label="Brand" Variant="Variant.Outlined">
            <MudSelectItem T="long?" Value="@((long?)null)">All brands</MudSelectItem>
            @foreach (var brand in _brands)
            {
                <MudSelectItem T="long?" Value="@((long?)brand.Id)">@brand.Name</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
</MudGrid>

@if (_showForm)
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-3">@(_editingProductId is null ? "New Product" : "Edit Product")</MudText>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formName" Label="Name" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_formDescription" Label="Description" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="long?" @bind-Value="_formCategoryId" Label="Category" Variant="Variant.Outlined">
                    <MudSelectItem T="long?" Value="@((long?)null)">(None)</MudSelectItem>
                    @foreach (var category in _categories)
                    {
                        <MudSelectItem T="long?" Value="@((long?)category.Id)">@category.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="long?" @bind-Value="_formBrandId" Label="Brand" Variant="Variant.Outlined">
                    <MudSelectItem T="long?" Value="@((long?)null)">(None)</MudSelectItem>
                    @foreach (var brand in _brands)
                    {
                        <MudSelectItem T="long?" Value="@((long?)brand.Id)">@brand.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="long?" @bind-Value="_formUnitId" Label="Unit" Variant="Variant.Outlined">
                    <MudSelectItem T="long?" Value="@((long?)null)">(None)</MudSelectItem>
                    @foreach (var unit in _units)
                    {
                        <MudSelectItem T="long?" Value="@((long?)unit.Id)">@unit.Name (@unit.ShortCode)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-center">
                <MudCheckBox T="bool" @bind-Value="_formManageStock" Label="Manage stock" />
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-center">
                <MudCheckBox T="bool" @bind-Value="_formNotForSelling" Label="Not for selling" />
            </MudItem>
        </MudGrid>
        <MudStack Row="true" Class="mt-4" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveProductAsync" Disabled="@_isSaving">Save</MudButton>
            <MudButton Variant="Variant.Text" OnClick="CancelForm">Close</MudButton>
        </MudStack>

        @if (_editingProductId is not null)
        {
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle1">Variants</MudText>
            <MudText Typo="Typo.body2" Class="mb-2" Style="color: var(--mud-palette-text-secondary);">
                All variants sell in this product's unit: @(_units.FirstOrDefault(u => u.Id == _formUnitId)?.Name ?? "(none selected)")
            </MudText>

            @if (_canViewStock && _branches.Count > 0)
            {
                <MudGrid Class="mb-2">
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="long?" Value="_stockBranchId" ValueChanged="OnStockBranchChangedAsync" Label="Stock branch" Variant="Variant.Outlined" Margin="Margin.Dense">
                            @foreach (var branch in _branches)
                            {
                                <MudSelectItem T="long?" Value="@((long?)branch.Id)">@branch.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
                <MudText Typo="Typo.caption" Class="mb-2" Style="color: var(--mud-palette-text-secondary); display:block;">
                    The Stock column below is editable for the selected branch. Use the Stock Adjustments page to see and manage quantities across every branch at once.
                </MudText>
            }

            @if (_editingVariants.Count > 0)
            {
                <MudTable Items="@_editingVariants" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>SKU</MudTh>
                        <MudTh>Variant (Size/Color/etc.)</MudTh>
                        <MudTh>Barcode</MudTh>
                        <MudTh>Cost</MudTh>
                        <MudTh>Price</MudTh>
                        <MudTh>Compare-at</MudTh>
                        <MudTh>Tax %</MudTh>
                        <MudTh>Reorder pt</MudTh>
                        <MudTh>Expiry</MudTh>
                        <MudTh>Stock</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="SKU">@context.Sku</MudTd>
                        <MudTd DataLabel="Variant">@GetVariantAttributeLabel(context)</MudTd>
                        <MudTd DataLabel="Barcode">@context.Barcode</MudTd>
                        <MudTd DataLabel="Cost">@(context.CostPrice?.ToString("0.00") ?? "-")</MudTd>
                        <MudTd DataLabel="Price">@context.Price.ToString("0.00")</MudTd>
                        <MudTd DataLabel="Compare-at">@(context.CompareAtPrice?.ToString("0.00") ?? "-")</MudTd>
                        <MudTd DataLabel="Tax %">@context.TaxRate.ToString("0.##") (@context.TaxType)</MudTd>
                        <MudTd DataLabel="Reorder pt">@(context.ReorderPoint?.ToString("0.###") ?? "-")</MudTd>
                        <MudTd DataLabel="Expiry">
                            @(context.ExpiryDate?.ToString("d") ?? "-")
                            @if (IsVariantNearExpiry(context))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="ml-1">Near expiry</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Stock">
                            @if (_canAdjustStock && _stockBranchId is not null)
                            {
                                <MudNumericField T="decimal" Value="@GetVariantStockInput(context.Id)" ValueChanged="@(v => SetVariantStockInput(context.Id, v))"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Style="width:100px" />
                            }
                            else if (_canViewStock)
                            {
                                @GetVariantTotalStock(context.Id).ToString("0.###")
                            }
                            else
                            {
                                <text>-</text>
                            }
                            @if (IsVariantLowStock(context))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="ml-1">Low</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                                @(context.IsActive ? "Active" : "Inactive")
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            @if (context.IsActive)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.PauseCircle" Size="Size.Small" OnClick="@(() => DeactivateVariantAsync(context.Id))" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" OnClick="@(() => ActivateVariantAsync(context.Id))" />
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => RemoveVariantAsync(context.Id))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                @if (_canAdjustStock && _stockBranchId is not null)
                {
                    <MudGrid Class="mt-3">
                        <MudItem xs="12" sm="6" md="4">
                            <MudTextField @bind-Value="_stockReason" Label="Reason" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Initial stock" />
                        </MudItem>
                    </MudGrid>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2" OnClick="SaveAllVariantStockAsync" Disabled="@_isSavingStock">
                        Save Stock
                    </MudButton>
                }
            }

            <MudText Typo="Typo.subtitle2" Class="mt-2">Add variants</MudText>
            <MudText Typo="Typo.body2" Class="mb-2" Style="color: var(--mud-palette-text-secondary);">
                Select the attribute values that apply (e.g. sizes, colors) and generate one variant per combination in a single step - e.g. 7 sizes x 2 colors creates 14 variants. Leave everything unchecked to add a single plain variant.
            </MudText>

            @if (_attributes.Count > 0)
            {
                @foreach (var attribute in _attributes)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-1">
                        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@(attribute.Name)</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => ToggleSelectAllForGenAttribute(attribute))">
                            @(AreAllGenValuesSelected(attribute) ? "Clear all" : "Select all")
                        </MudButton>
                    </MudStack>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" Class="mb-3">
                        @foreach (var value in attribute.Values)
                        {
                            <MudCheckBox T="bool"
                                         Value="@_genSelectedValueIds.Contains(value.Id)"
                                         ValueChanged="@((bool v) => ToggleGenValue(value.Id, v))"
                                         Label="@value.Value"
                                         Dense="true" />
                        }
                    </MudStack>
                }
            }

            <MudGrid>
                @if (GetGenCombinationCount() <= 1)
                {
                    <MudItem xs="12" sm="6" md="3">
                        <MudTextField @bind-Value="_genSku" Label="SKU (optional - auto-generated)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudTextField @bind-Value="_genBarcode" Label="Barcode (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                }
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField T="decimal?" Value="_genCostPrice" ValueChanged="OnGenCostPriceChanged" Label="Cost price (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField @bind-Value="_genReorderPoint" Label="Reorder point (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker @bind-Date="_genExpiryDate" Label="Expiry date (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3" Class="d-flex align-center">
                    <MudSwitch T="bool" Value="_genUseProfitPercent" ValueChanged="OnGenUseProfitPercentChanged" Label="Price by profit %" Color="Color.Primary" />
                </MudItem>
                @if (_genUseProfitPercent)
                {
                    <MudItem xs="12" sm="6" md="3">
                        <MudNumericField T="decimal" Value="_genProfitPercent" ValueChanged="OnGenProfitPercentChanged" Label="Profit %" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                    </MudItem>
                }
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField @bind-Value="_genPrice" Label="Selling price" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Disabled="@_genUseProfitPercent" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField @bind-Value="_genCompareAtPrice" Label="Compare-at price (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField @bind-Value="_genTaxRate" Label="Tax rate %" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="100" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string" @bind-Value="_genTaxType" Label="Selling price tax type" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var type in TaxTypes)
                        {
                            <MudSelectItem T="string" Value="@type">@type</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string" @bind-Value="_genBarcodeType" Label="Barcode type" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var type in BarcodeTypes)
                        {
                            <MudSelectItem T="string" Value="@type">@type</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField @bind-Value="_genWeight" Label="Weight (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudNumericField @bind-Value="_genLength" Label="Length (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudNumericField @bind-Value="_genWidth" Label="Width (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudNumericField @bind-Value="_genHeight" Label="Height (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                </MudItem>
            </MudGrid>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2" OnClick="GenerateVariantsAsync" Disabled="@_isGeneratingVariants">
                Generate @GetGenCombinationCount() variant(s)
            </MudButton>

            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle1" Class="mb-2">Images</MudText>

            @if (_editingImages.Count > 0)
            {
                @foreach (var image in _editingImages)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                        <MudText Typo="Typo.body2" Style="word-break: break-all;">@image.Url</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => RemoveImageAsync(image.Id))" />
                    </MudStack>
                }
            }

            <MudStack Row="true" Spacing="2" Class="mt-2" AlignItems="AlignItems.Center">
                <MudTextField @bind-Value="_imageUrl" Label="Image URL" Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="AddImageAsync">Add</MudButton>
            </MudStack>
        }
    </MudPaper>
}

<MudTable Items="@_products" Hover="true" Dense="true" Loading="@_isLoading">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Category</MudTh>
        <MudTh>Brand</MudTh>
        <MudTh>Variants</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Category">@(context.CategoryName ?? "-")</MudTd>
        <MudTd DataLabel="Brand">@(context.BrandName ?? "-")</MudTd>
        <MudTd DataLabel="Variants">@context.Variants.Count</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                @(context.IsActive ? "Active" : "Inactive")
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Actions">
            @if (_canEdit)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => ShowEditFormAsync(context.Id))" />
                @if (context.IsActive)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PauseCircle" Size="Size.Small" OnClick="@(() => DeactivateProductAsync(context.Id))" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" OnClick="@(() => ActivateProductAsync(context.Id))" />
                }
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => DeleteProductAsync(context.Id))" />
            }
        </MudTd>
    </RowTemplate>
</MudTable>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="mt-4" Spacing="4">
    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Disabled="@(_page <= 1)" OnClick="@(() => ChangePageAsync(_page - 1))" />
    <MudText Typo="Typo.body2">Page @_page of @_totalPages</MudText>
    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Disabled="@(_page >= _totalPages)" OnClick="@(() => ChangePageAsync(_page + 1))" />
</MudStack>

}

@code {
    private const int PageSize = 25;

    private static readonly IReadOnlyList<string> BarcodeTypes = new List<string> { "C128", "C39", "EAN13", "EAN8", "UPCA", "UPCE", "QRCODE" };
    private static readonly IReadOnlyList<string> TaxTypes = new List<string> { "Exclusive", "Inclusive" };

    private IReadOnlyList<ProductDto> _products = new List<ProductDto>();
    private IReadOnlyList<CategoryDto> _categories = new List<CategoryDto>();
    private IReadOnlyList<BrandDto> _brands = new List<BrandDto>();
    private IReadOnlyList<UnitDto> _units = new List<UnitDto>();
    private IReadOnlyList<ProductAttributeDto> _attributes = new List<ProductAttributeDto>();
    private IReadOnlyList<BranchDto> _branches = new List<BranchDto>();
    private List<StockItemDto> _stockItems = new();
    private HashSet<string> _permissions = new();

    private bool _isLoading = true;
    private bool _isSaving;
    private string _search = string.Empty;
    private long? _filterCategoryId;
    private long? _filterBrandId;
    private int _page = 1;
    private long _totalCount;
    private int _totalPages = 1;

    private bool _showForm;
    private long? _editingProductId;
    private string _formName = string.Empty;
    private string? _formDescription;
    private long? _formCategoryId;
    private long? _formBrandId;
    private long? _formUnitId;
    private bool _formManageStock = true;
    private bool _formNotForSelling;

    private List<ProductVariantDto> _editingVariants = new();
    private List<ProductImageDto> _editingImages = new();

    private string? _genSku;
    private string? _genBarcode;
    private HashSet<long> _genSelectedValueIds = new();
    private decimal? _genCostPrice;
    private bool _genUseProfitPercent;
    private decimal _genProfitPercent;
    private decimal _genPrice;
    private decimal? _genCompareAtPrice;
    private decimal _genTaxRate;
    private string _genTaxType = "Exclusive";
    private string _genBarcodeType = "C128";
    private decimal? _genWeight;
    private decimal? _genLength;
    private decimal? _genWidth;
    private decimal? _genHeight;
    private decimal? _genReorderPoint;
    private DateTime? _genExpiryDate;
    private bool _isGeneratingVariants;

    private string _imageUrl = string.Empty;

    private long? _stockBranchId;
    private readonly Dictionary<long, decimal> _variantStockInputs = new();
    private string? _stockReason;
    private bool _isSavingStock;

    private bool _canView
    {
        get { return _permissions.Contains("catalog.products.view"); }
    }

    private bool _canEdit
    {
        get { return _permissions.Contains("catalog.products.edit"); }
    }

    private bool _canViewStock
    {
        get { return _permissions.Contains("inventory.stock.view"); }
    }

    private bool _canAdjustStock
    {
        get { return _permissions.Contains("inventory.adjustment.create"); }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _permissions = state.User.FindAll("permission").Select(c => c.Value).ToHashSet();

        if (_canView)
        {
            var categoriesResult = await ApiClient.GetCategoriesAsync(includeInactive: true);
            if (categoriesResult.Success && categoriesResult.Data is not null)
            {
                _categories = categoriesResult.Data;
            }

            var brandsResult = await ApiClient.GetBrandsAsync(includeInactive: true);
            if (brandsResult.Success && brandsResult.Data is not null)
            {
                _brands = brandsResult.Data;
            }

            var unitsResult = await ApiClient.GetUnitsAsync(includeInactive: true);
            if (unitsResult.Success && unitsResult.Data is not null)
            {
                _units = unitsResult.Data;
            }

            var attributesResult = await ApiClient.GetProductAttributesAsync();
            if (attributesResult.Success && attributesResult.Data is not null)
            {
                _attributes = attributesResult.Data;
            }

            var branchesResult = await ApiClient.GetBranchesAsync(includeInactive: true);
            if (branchesResult.Success && branchesResult.Data is not null)
            {
                _branches = branchesResult.Data;
            }

            await LoadAsync();
        }
        else
        {
            _isLoading = false;
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        var result = await ApiClient.GetProductsAsync(_page, PageSize, string.IsNullOrWhiteSpace(_search) ? null : _search, _filterCategoryId, _filterBrandId);
        if (result.Success && result.Data is not null)
        {
            _products = result.Data.Data;
            _totalCount = result.Data.TotalCount;
            _totalPages = Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to load products.", Severity.Error);
        }

        _isLoading = false;
    }

    private async Task OnSearchChanged(string value)
    {
        _search = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task OnFilterCategoryChanged(long? value)
    {
        _filterCategoryId = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task OnFilterBrandChanged(long? value)
    {
        _filterBrandId = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task ChangePageAsync(int newPage)
    {
        _page = newPage;
        await LoadAsync();
    }

    private void ShowCreateForm()
    {
        _editingProductId = null;
        _formName = string.Empty;
        _formDescription = null;
        _formCategoryId = null;
        _formBrandId = null;
        _formUnitId = null;
        _formManageStock = true;
        _formNotForSelling = false;
        _editingVariants = new List<ProductVariantDto>();
        _editingImages = new List<ProductImageDto>();
        _stockItems = new List<StockItemDto>();
        _stockBranchId = null;
        _variantStockInputs.Clear();
        ResetGenerateForm();
        _showForm = true;
    }

    private async Task ShowEditFormAsync(long productId)
    {
        var result = await ApiClient.GetProductByIdAsync(productId);
        if (!result.Success || result.Data is null)
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to load product.", Severity.Error);
            return;
        }

        var product = result.Data;
        _editingProductId = product.Id;
        _formName = product.Name;
        _formDescription = product.Description;
        _formCategoryId = product.CategoryId;
        _formBrandId = product.BrandId;
        _formUnitId = product.UnitId;
        _formManageStock = product.ManageStock;
        _formNotForSelling = product.NotForSelling;
        _editingVariants = product.Variants.ToList();
        _editingImages = product.Images.ToList();
        ResetGenerateForm();
        _showForm = true;

        await LoadStockItemsAsync();
    }

    private async Task LoadStockItemsAsync()
    {
        if (_editingProductId is null || !_canViewStock)
        {
            _stockItems = new List<StockItemDto>();
            return;
        }

        var stockResult = await ApiClient.GetStockItemsAsync(1, 500, null, _editingProductId.Value);
        _stockItems = stockResult.Success && stockResult.Data is not null ? stockResult.Data.Data.ToList() : new List<StockItemDto>();

        if (_canAdjustStock)
        {
            if (_stockBranchId is null)
            {
                _stockBranchId = _branches.FirstOrDefault()?.Id;
            }
            InitializeVariantStockInputs();
        }
    }

    private decimal GetVariantTotalStock(long variantId)
    {
        return _stockItems.Where(s => s.ProductVariantId == variantId).Sum(s => s.QuantityOnHand);
    }

    private async Task OnStockBranchChangedAsync(long? branchId)
    {
        _stockBranchId = branchId;
        InitializeVariantStockInputs();
        await Task.CompletedTask;
    }

    private void InitializeVariantStockInputs()
    {
        _variantStockInputs.Clear();

        if (_stockBranchId is null)
        {
            return;
        }

        foreach (var variant in _editingVariants)
        {
            var existing = _stockItems.FirstOrDefault(s => s.ProductVariantId == variant.Id && s.BranchId == _stockBranchId.Value);
            _variantStockInputs[variant.Id] = existing != null ? existing.QuantityOnHand : 0;
        }
    }

    private decimal GetVariantStockInput(long variantId)
    {
        decimal value;
        return _variantStockInputs.TryGetValue(variantId, out value) ? value : 0;
    }

    private void SetVariantStockInput(long variantId, decimal value)
    {
        _variantStockInputs[variantId] = value;
    }

    private async Task SaveAllVariantStockAsync()
    {
        if (_stockBranchId is null)
        {
            Snackbar.Add("Select a branch first.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_stockReason))
        {
            Snackbar.Add("Reason is required.", Severity.Warning);
            return;
        }

        var changes = _editingVariants
            .Select(v => new { Variant = v, Delta = GetVariantStockInput(v.Id) - GetCurrentBranchQty(v.Id) })
            .Where(x => x.Delta != 0)
            .ToList();

        if (changes.Count == 0)
        {
            Snackbar.Add("No stock changes to save.", Severity.Warning);
            return;
        }

        _isSavingStock = true;
        var successCount = 0;
        var failureCount = 0;

        foreach (var change in changes)
        {
            var result = await ApiClient.AdjustStockAsync(new AdjustStockRequest
            {
                ProductVariantId = change.Variant.Id,
                BranchId = _stockBranchId.Value,
                QuantityDelta = change.Delta,
                Reason = _stockReason,
            });

            if (result.Success)
            {
                successCount++;
            }
            else
            {
                failureCount++;
            }
        }

        if (failureCount == 0)
        {
            Snackbar.Add($"Saved stock for {successCount} variant(s).", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Saved {successCount} variant(s); {failureCount} failed (e.g. would result in negative stock).", Severity.Warning);
        }

        _stockReason = null;
        await LoadStockItemsAsync();

        _isSavingStock = false;
    }

    private decimal GetCurrentBranchQty(long variantId)
    {
        if (_stockBranchId is null)
        {
            return 0;
        }

        var item = _stockItems.FirstOrDefault(s => s.ProductVariantId == variantId && s.BranchId == _stockBranchId.Value);
        return item != null ? item.QuantityOnHand : 0;
    }

    private string GetVariantAttributeLabel(ProductVariantDto variant)
    {
        if (variant.AttributeValueIds.Count == 0)
        {
            return "-";
        }

        var parts = new List<string>();
        foreach (var attribute in _attributes)
        {
            var matched = attribute.Values
                .Where(v => variant.AttributeValueIds.Contains(v.Id))
                .Select(v => v.Value)
                .ToList();

            if (matched.Count > 0)
            {
                parts.Add($"{attribute.Name}: {string.Join(", ", matched)}");
            }
        }

        return parts.Count > 0 ? string.Join(" | ", parts) : "-";
    }

    private bool IsVariantLowStock(ProductVariantDto variant)
    {
        return _canViewStock && variant.ReorderPoint.HasValue && GetVariantTotalStock(variant.Id) <= variant.ReorderPoint.Value;
    }

    private static bool IsVariantNearExpiry(ProductVariantDto variant)
    {
        return variant.ExpiryDate.HasValue && variant.ExpiryDate.Value <= DateTime.Today.AddDays(30);
    }

    private void ResetGenerateForm()
    {
        _genSku = null;
        _genBarcode = null;
        _genSelectedValueIds = new HashSet<long>();
        _genCostPrice = null;
        _genUseProfitPercent = false;
        _genProfitPercent = 0;
        _genPrice = 0;
        _genCompareAtPrice = null;
        _genTaxRate = 0;
        _genTaxType = "Exclusive";
        _genBarcodeType = "C128";
        _genWeight = null;
        _genLength = null;
        _genWidth = null;
        _genHeight = null;
        _genReorderPoint = null;
        _genExpiryDate = null;
        _imageUrl = string.Empty;
    }

    private void ToggleGenValue(long valueId, bool isSelected)
    {
        if (isSelected)
        {
            _genSelectedValueIds.Add(valueId);
        }
        else
        {
            _genSelectedValueIds.Remove(valueId);
        }
    }

    private bool AreAllGenValuesSelected(ProductAttributeDto attribute)
    {
        return attribute.Values.Count > 0 && attribute.Values.All(v => _genSelectedValueIds.Contains(v.Id));
    }

    private void ToggleSelectAllForGenAttribute(ProductAttributeDto attribute)
    {
        if (AreAllGenValuesSelected(attribute))
        {
            foreach (var value in attribute.Values)
            {
                _genSelectedValueIds.Remove(value.Id);
            }
        }
        else
        {
            foreach (var value in attribute.Values)
            {
                _genSelectedValueIds.Add(value.Id);
            }
        }
    }

    private void OnGenCostPriceChanged(decimal? value)
    {
        _genCostPrice = value;
        RecalculateGenPrice();
    }

    private void OnGenProfitPercentChanged(decimal value)
    {
        _genProfitPercent = value;
        RecalculateGenPrice();
    }

    private void OnGenUseProfitPercentChanged(bool value)
    {
        _genUseProfitPercent = value;
        if (value)
        {
            RecalculateGenPrice();
        }
    }

    private void RecalculateGenPrice()
    {
        if (_genUseProfitPercent && _genCostPrice.HasValue && _genCostPrice.Value > 0)
        {
            _genPrice = Math.Round(_genCostPrice.Value * (1 + _genProfitPercent / 100m), 2);
        }
    }

    private List<List<long>> GetGenCombinations()
    {
        var groups = _attributes
            .Select(a => a.Values.Where(v => _genSelectedValueIds.Contains(v.Id)).Select(v => v.Id).ToList())
            .Where(list => list.Count > 0)
            .ToList();

        if (groups.Count == 0)
        {
            return new List<List<long>> { new List<long>() };
        }

        IEnumerable<List<long>> combinations = new List<List<long>> { new List<long>() };
        foreach (var valueGroup in groups)
        {
            combinations = from prefix in combinations
                           from valueId in valueGroup
                           select new List<long>(prefix) { valueId };
        }

        return combinations.ToList();
    }

    private int GetGenCombinationCount()
    {
        return GetGenCombinations().Count;
    }

    private async Task GenerateVariantsAsync()
    {
        if (_editingProductId is null)
        {
            return;
        }

        if (_genUseProfitPercent && (_genCostPrice is null || _genCostPrice <= 0))
        {
            Snackbar.Add("Cost price is required to calculate the selling price by profit %.", Severity.Warning);
            return;
        }

        var combinations = GetGenCombinations();

        var applyManualSkuAndBarcode = combinations.Count == 1;

        _isGeneratingVariants = true;
        var successCount = 0;
        var failureCount = 0;

        foreach (var combination in combinations)
        {
            var result = await ApiClient.AddVariantAsync(_editingProductId.Value, new AddVariantRequest
            {
                Sku = applyManualSkuAndBarcode && !string.IsNullOrWhiteSpace(_genSku) ? _genSku : null,
                Barcode = applyManualSkuAndBarcode && !string.IsNullOrWhiteSpace(_genBarcode) ? _genBarcode : null,
                Price = _genPrice,
                CompareAtPrice = _genCompareAtPrice,
                CostPrice = _genCostPrice,
                TaxRate = _genTaxRate,
                TaxType = _genTaxType,
                BarcodeType = _genBarcodeType,
                Weight = _genWeight,
                Length = _genLength,
                Width = _genWidth,
                Height = _genHeight,
                ReorderPoint = _genReorderPoint,
                ExpiryDate = _genExpiryDate,
                AttributeValueIds = combination,
            });

            if (result.Success && result.Data is not null)
            {
                successCount++;
                _editingVariants = result.Data.Variants.ToList();
            }
            else
            {
                failureCount++;
            }
        }

        if (failureCount == 0)
        {
            Snackbar.Add($"Created {successCount} variant(s).", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Created {successCount} variant(s); {failureCount} failed (likely a duplicate combination already on this product).", Severity.Warning);
        }

        ResetGenerateForm();
        await LoadAsync();

        _isGeneratingVariants = false;
    }

    private void CancelForm()
    {
        _showForm = false;
    }

    private async Task SaveProductAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            Snackbar.Add("Product name is required.", Severity.Warning);
            return;
        }

        _isSaving = true;

        if (_editingProductId is null)
        {
            var createResult = await ApiClient.CreateProductAsync(new CreateProductRequest
            {
                Name = _formName,
                Description = _formDescription,
                CategoryId = _formCategoryId,
                BrandId = _formBrandId,
                UnitId = _formUnitId,
                ManageStock = _formManageStock,
                NotForSelling = _formNotForSelling,
            });

            if (createResult.Success && createResult.Data is not null)
            {
                Snackbar.Add("Product created - you can now add variants and images below.", Severity.Success);
                _editingProductId = createResult.Data.Id;
                _editingVariants = createResult.Data.Variants.ToList();
                _editingImages = createResult.Data.Images.ToList();
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(createResult.Error?.Message ?? "Failed to create product.", Severity.Error);
            }
        }
        else
        {
            var updateResult = await ApiClient.UpdateProductAsync(_editingProductId.Value, new UpdateProductRequest
            {
                Name = _formName,
                Description = _formDescription,
                CategoryId = _formCategoryId,
                BrandId = _formBrandId,
                UnitId = _formUnitId,
                ManageStock = _formManageStock,
                NotForSelling = _formNotForSelling,
            });

            if (updateResult.Success)
            {
                Snackbar.Add("Product saved.", Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(updateResult.Error?.Message ?? "Failed to save product.", Severity.Error);
            }
        }

        _isSaving = false;
    }

