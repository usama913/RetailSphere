@page "/notifications"
@using RetailSphere.Contracts.Notifications
@attribute [Authorize]
@inject IApiClient ApiClient
@inject ISnackbar Snackbar

<PageTitle>Notifications - RetailSphere</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <div>
        <MudText Typo="Typo.h5">Notifications</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            Supplier and customer payment/invoice alerts — payments due, overdue invoices, and credit limit breaches.
        </MudText>
    </div>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudSwitch T="bool" Value="_unreadOnly" ValueChanged="OnUnreadOnlyChangedAsync" Label="Unread only" Color="Color.Primary" />
        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync">Refresh</MudButton>
    </MudStack>
</MudStack>

@if (_list is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_list.Items.Count == 0)
{
    <MudAlert Severity="Severity.Info">@(_unreadOnly ? "No unread notifications." : "No notifications yet.")</MudAlert>
}
else
{
    <MudPaper Class="pa-2" Elevation="1">
        <MudList T="NotificationDto" Clickable="false">
            @foreach (var notification in _list.Items)
            {
                <MudListItem T="NotificationDto" Class="@(notification.IsRead ? "" : "rs-notification-unread")">
                    <ChildContent>
                        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="py-1" Style="width:100%;">
                            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
                                <MudIcon Icon="@GetSeverityIcon(notification.Severity)" Color="@GetSeverityColor(notification.Severity)" Class="mt-1" />
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body1" Style="@(notification.IsRead ? null : "font-weight:600;")">@notification.Message</MudText>
                                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                                        @notification.Type · @notification.CreatedAtUtc.ToLocalTime().ToString("g")
                                        @if (notification.IsRead && notification.ReadAtUtc.HasValue)
                                        {
                                            <span> · read @notification.ReadAtUtc.Value.ToLocalTime().ToString("g")</span>
                                        }
                                    </MudText>
                                </MudStack>
                            </MudStack>
                            @if (!notification.IsRead)
                            {
                                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => MarkAsReadAsync(notification))">Mark read</MudButton>
                            }
                        </MudStack>
                    </ChildContent>
                </MudListItem>
                <MudDivider />
            }
        </MudList>
    </MudPaper>

    <MudStack Row="true" Justify="Justify.Center" Class="mt-3">
        <MudPagination Count="@_totalPages" Selected="_page" SelectedChanged="ChangePageAsync" />
    </MudStack>
}

@code {
    private const int PageSize = 25;

    private bool _unreadOnly;
    private int _page = 1;
    private int _totalPages = 1;
    private int _totalCount;
    private NotificationListDto? _list;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OnUnreadOnlyChangedAsync(bool value)
    {
        _unreadOnly = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task ChangePageAsync(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var result = await ApiClient.GetNotificationsAsync(_unreadOnly, _page, PageSize);
        if (result.Success && result.Data is not null)
        {
            _list = result.Data;
            _totalCount = result.Data.Items.Count;
            _totalPages = Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to load notifications.", Severity.Error);
        }
    }

    private async Task MarkAsReadAsync(NotificationDto notification)
    {
        var result = await ApiClient.MarkNotificationAsReadAsync(notification.Id);
        if (result.Success)
        {
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to mark notification as read.", Severity.Error);
        }
    }

    private static string GetSeverityIcon(string severity) => severity switch
    {
        "Critical" => Icons.Material.Filled.ErrorOutline,
        "Warning" => Icons.Material.Filled.WarningAmber,
        _ => Icons.Material.Filled.OutlinedFlag,
    };

    private static Color GetSeverityColor(string severity) => severity switch
    {
        "Critical" => Color.Error,
        "Warning" => Color.Warning,
        _ => Color.Info,
    };
}
