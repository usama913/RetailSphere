@page "/inventory/stock"
@using RetailSphere.Contracts.Admin
@using RetailSphere.Contracts.Catalog
@using RetailSphere.Contracts.Inventory
@attribute [Authorize]
@inject IApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>Branch Stock - RetailSphere</PageTitle>

@if (!_canView)
{
    <MudAlert Severity="Severity.Warning">You don't have permission to view stock levels.</MudAlert>
}
else
{

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <div>
        <MudText Typo="Typo.h5">Branch Stock</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Quantity on hand per product variant, by branch.</MudText>
    </div>
    @if (_canAdjust)
    {
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.SwapHoriz" OnClick="ShowTransferForm">
                Transfer Stock
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Tune" OnClick="ShowAdjustForm">
                Adjust Stock
            </MudButton>
        </MudStack>
    }
</MudStack>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" md="4">
        <MudSelect T="long?" Value="_filterBranchId" ValueChanged="OnFilterBranchChanged" Label="Branch" Variant="Variant.Outlined">
            <MudSelectItem T="long?" Value="@((long?)null)">All branches</MudSelectItem>
            @foreach (var branch in _branches)
            {
                <MudSelectItem T="long?" Value="@((long?)branch.Id)">@branch.Name</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudSelect T="long?" Value="_filterProductId" ValueChanged="OnFilterProductChanged" Label="Product" Variant="Variant.Outlined">
            <MudSelectItem T="long?" Value="@((long?)null)">All products</MudSelectItem>
            @foreach (var product in _products)
            {
                <MudSelectItem T="long?" Value="@((long?)product.Id)">@product.Name</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
</MudGrid>

@if (_showAdjustForm)
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-3">Adjust Stock</MudText>

        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="long?" @bind-Value="_adjProductId" Label="Product" Variant="Variant.Outlined">
                    <MudSelectItem T="long?" Value="@((long?)null)">— Select —</MudSelectItem>
                    @foreach (var product in _products)
                    {
                        <MudSelectItem T="long?" Value="@((long?)product.Id)">@product.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="long?" @bind-Value="_adjVariantId" Label="Variant" Variant="Variant.Outlined">
                    <MudSelectItem T="long?" Value="@((long?)null)">— Select —</MudSelectItem>
                    @foreach (var variant in GetVariantsForAdjustProduct())
                    {
                        <MudSelectItem T="long?" Value="@((long?)variant.Id)">@GetVariantLabel(variant)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="long?" @bind-Value="_adjBranchId" Label="Branch" Variant="Variant.Outlined">
                    <MudSelectItem T="long?" Value="@((long?)null)">— Select —</MudSelectItem>
                    @foreach (var branch in _branches)
                    {
                        <MudSelectItem T="long?" Value="@((long?)branch.Id)">@branch.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudNumericField @bind-Value="_adjQuantityDelta" Label="Quantity change (+/-)" Variant="Variant.Outlined" HelperText="Positive to add, negative to remove" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_adjReason" Label="Reason" Variant="Variant.Outlined" Lines="2" Required="true" />
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-3" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAdjustAsync" Disabled="@_isAdjusting">Save Adjustment</MudButton>
            <MudButton Variant="Variant.Text" OnClick="@(() => _showAdjustForm = false)">Cancel</MudButton>
        </MudStack>
    </MudPaper>
}

@if (_showTransferForm)
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-1">Transfer Stock</MudText>
        <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
            Moves a quantity from one branch to another in a single step — decreases the source and increases the destination together, so the totals always stay correct.
        </MudText>

        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="long?" @bind-Value="_trProductId" Label="Product" Variant="Variant.Outlined">
                    <MudSelectItem T="long?" Value="@((long?)null)">— Select —</MudSelectItem>
                    @foreach (var product in _products)
                    {
                        <MudSelectItem T="long?" Value="@((long?)product.Id)">@product.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="long?" @bind-Value="_trVariantId" Label="Variant" Variant="Variant.Outlined">
                    <MudSelectItem T="long?" Value="@((long?)null)">— Select —</MudSelectItem>
                    @foreach (var variant in GetVariantsForTransferProduct())
                    {
                        <MudSelectItem T="long?" Value="@((long?)variant.Id)">@GetVariantLabel(variant)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="long?" @bind-Value="_trFromBranchId" Label="From branch" Variant="Variant.Outlined">
                    <MudSelectItem T="long?" Value="@((long?)null)">— Select —</MudSelectItem>
                    @foreach (var branch in _branches)
                    {
                        <MudSelectItem T="long?" Value="@((long?)branch.Id)">@branch.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="long?" @bind-Value="_trToBranchId" Label="To branch" Variant="Variant.Outlined">
                    <MudSelectItem T="long?" Value="@((long?)null)">— Select —</MudSelectItem>
                    @foreach (var branch in _branches)
                    {
                        <MudSelectItem T="long?" Value="@((long?)branch.Id)">@branch.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudNumericField @bind-Value="_trQuantity" Label="Quantity to move" Variant="Variant.Outlined" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="9">
                <MudTextField @bind-Value="_trReason" Label="Reason" Variant="Variant.Outlined" Required="true" />
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-3" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitTransferAsync" Disabled="@_isTransferring">Transfer</MudButton>
            <MudButton Variant="Variant.Text" OnClick="@(() => _showTransferForm = false)">Cancel</MudButton>
        </MudStack>
    </MudPaper>
}

<MudTable Items="@_stockItems" Hover="true" Dense="true" Loading="@_isLoading">
    <HeaderContent>
        <MudTh>SKU</MudTh>
        <MudTh>Product</MudTh>
        <MudTh>Branch</MudTh>
        <MudTh>Qty on hand</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="SKU">@(context.Sku ?? "—")</MudTd>
        <MudTd DataLabel="Product">@(context.ProductName ?? "—")</MudTd>
        <MudTd DataLabel="Branch">@(context.BranchName ?? "—")</MudTd>
        <MudTd DataLabel="Qty on hand">@context.QuantityOnHand</MudTd>
        <MudTd DataLabel="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => ToggleHistory(context.Id))" />
        </MudTd>
    </RowTemplate>
</MudTable>

@if (_expandedStockItemId is not null)
{
    var expanded = _stockItems.FirstOrDefault(s => s.Id == _expandedStockItemId);
    if (expanded is not null)
    {
        <MudPaper Class="pa-4 mt-2" Elevation="1">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Adjustment History — @(expanded.Sku ?? expanded.Id.ToString())</MudText>
            @if (expanded.Adjustments.Count == 0)
            {
                <MudText Typo="Typo.body2">No adjustments recorded.</MudText>
            }
            else
            {
                <MudTable Items="@expanded.Adjustments" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Change</MudTh>
                        <MudTh>Source</MudTh>
                        <MudTh>Reason</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Date">@context.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</MudTd>
                        <MudTd DataLabel="Change">@(context.QuantityDelta > 0 ? "+" : string.Empty)@context.QuantityDelta</MudTd>
                        <MudTd DataLabel="Source">@context.Source</MudTd>
                        <MudTd DataLabel="Reason">@context.Reason</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    }
}

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="mt-4" Spacing="4">
    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Disabled="@(_page <= 1)" OnClick="@(() => ChangePageAsync(_page - 1))" />
    <MudText Typo="Typo.body2">Page @_page of @_totalPages</MudText>
    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Disabled="@(_page >= _totalPages)" OnClick="@(() => ChangePageAsync(_page + 1))" />
</MudStack>

}

@code {
    private const int PageSize = 25;

    private IReadOnlyList<StockItemDto> _stockItems = [];
    private IReadOnlyList<BranchDto> _branches = [];
    private IReadOnlyList<ProductDto> _products = [];
    private IReadOnlyList<ProductAttributeDto> _attributes = [];
    private HashSet<string> _permissions = [];

    private bool _isLoading = true;
    private bool _isAdjusting;
    private long? _filterBranchId;
    private long? _filterProductId;
    private int _page = 1;
    private long _totalCount;
    private int _totalPages = 1;

    private long? _expandedStockItemId;

    private bool _showAdjustForm;
    private long? _adjProductId;
    private long? _adjVariantId;
    private long? _adjBranchId;
    private decimal _adjQuantityDelta;
    private string _adjReason = string.Empty;

    private bool _showTransferForm;
    private bool _isTransferring;
    private long? _trProductId;
    private long? _trVariantId;
    private long? _trFromBranchId;
    private long? _trToBranchId;
    private decimal _trQuantity;
    private string _trReason = string.Empty;

    private bool _canView => _permissions.Contains("inventory.stock.view");
    private bool _canAdjust => _permissions.Contains("inventory.adjustment.create");

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _permissions = state.User.FindAll("permission").Select(c => c.Value).ToHashSet();

        if (_canView)
        {
            var branchesResult = await ApiClient.GetBranchesAsync(includeInactive: true);
            if (branchesResult.Success && branchesResult.Data is not null)
                _branches = branchesResult.Data;

            var productsResult = await ApiClient.GetProductsAsync(1, 1000);
            if (productsResult.Success && productsResult.Data is not null)
                _products = productsResult.Data.Data;

            var attributesResult = await ApiClient.GetProductAttributesAsync();
            if (attributesResult.Success && attributesResult.Data is not null)
                _attributes = attributesResult.Data;

            await LoadAsync();
        }
        else
        {
            _isLoading = false;
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        var result = await ApiClient.GetStockItemsAsync(_page, PageSize, _filterBranchId, _filterProductId);

        if (result.Success && result.Data is not null)
        {
            _stockItems = result.Data.Data;
            _totalCount = result.Data.TotalCount;
            _totalPages = Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to load stock levels.", Severity.Error);
        }

        _isLoading = false;
    }

    private async Task OnFilterBranchChanged(long? value)
    {
        _filterBranchId = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task OnFilterProductChanged(long? value)
    {
        _filterProductId = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task ChangePageAsync(int newPage)
    {
        _page = newPage;
        await LoadAsync();
    }

    private void ToggleHistory(long stockItemId)
    {
        _expandedStockItemId = _expandedStockItemId == stockItemId ? null : stockItemId;
    }

    private IReadOnlyList<ProductVariantDto> GetVariantsForAdjustProduct()
    {
        if (_adjProductId is null) return [];
        var product = _products.FirstOrDefault(p => p.Id == _adjProductId.Value);
        return product?.Variants ?? [];
    }

    /// <summary>SKU plus its attribute values (e.g. "P5-V07 — Size: 39") so variants aren't just an opaque code in the dropdown.</summary>
    private string GetVariantLabel(ProductVariantDto variant)
    {
        if (variant.AttributeValueIds.Count == 0)
            return variant.Sku;

        var parts = new List<string>();
        foreach (var attribute in _attributes)
        {
            var matched = attribute.Values
                .Where(v => variant.AttributeValueIds.Contains(v.Id))
                .Select(v => v.Value)
                .ToList();

            if (matched.Count > 0)
                parts.Add($"{attribute.Name}: {string.Join(", ", matched)}");
        }

        return parts.Count > 0 ? $"{variant.Sku} — {string.Join(" · ", parts)}" : variant.Sku;
    }

    private void ShowAdjustForm()
    {
        _adjProductId = null;
        _adjVariantId = null;
        _adjBranchId = null;
        _adjQuantityDelta = 0;
        _adjReason = string.Empty;
        _showAdjustForm = true;
    }

    private async Task SubmitAdjustAsync()
    {
        if (_adjVariantId is null || _adjBranchId is null)
        {
            Snackbar.Add("Select a product variant and branch.", Severity.Warning);
            return;
        }

        if (_adjQuantityDelta == 0)
        {
            Snackbar.Add("Quantity change cannot be zero.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_adjReason))
        {
            Snackbar.Add("Reason is required.", Severity.Warning);
            return;
        }

        _isAdjusting = true;

        var result = await ApiClient.AdjustStockAsync(new AdjustStockRequest
        {
            ProductVariantId = _adjVariantId.Value,
            BranchId = _adjBranchId.Value,
            QuantityDelta = _adjQuantityDelta,
            Reason = _adjReason,
        });

        if (result.Success && result.Data is not null)
        {
            Snackbar.Add("Stock adjusted.", Severity.Success);
            _showAdjustForm = false;
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to adjust stock.", Severity.Error);
        }

        _isAdjusting = false;
    }

    private IReadOnlyList<ProductVariantDto> GetVariantsForTransferProduct()
    {
        if (_trProductId is null) return [];
        var product = _products.FirstOrDefault(p => p.Id == _trProductId.Value);
        return product?.Variants ?? [];
    }

    private void ShowTransferForm()
    {
        _trProductId = null;
        _trVariantId = null;
        _trFromBranchId = null;
        _trToBranchId = null;
        _trQuantity = 0;
        _trReason = string.Empty;
        _showTransferForm = true;
    }

    private async Task SubmitTransferAsync()
    {
        if (_trVariantId is null || _trFromBranchId is null || _trToBranchId is null)
        {
            Snackbar.Add("Select a product variant, source branch, and destination branch.", Severity.Warning);
            return;
        }

        if (_trFromBranchId == _trToBranchId)
        {
            Snackbar.Add("Source and destination branches must be different.", Severity.Warning);
            return;
        }

        if (_trQuantity <= 0)
        {
            Snackbar.Add("Enter a quantity greater than zero.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_trReason))
        {
            Snackbar.Add("Reason is required.", Severity.Warning);
            return;
        }

        _isTransferring = true;

        var result = await ApiClient.TransferStockAsync(new TransferStockRequest
        {
            ProductVariantId = _trVariantId.Value,
            FromBranchId = _trFromBranchId.Value,
            ToBranchId = _trToBranchId.Value,
            Quantity = _trQuantity,
            Reason = _trReason,
        });

        if (result.Success)
        {
            Snackbar.Add("Stock transferred.", Severity.Success);
            _showTransferForm = false;
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to transfer stock.", Severity.Error);
        }

        _isTransferring = false;
    }
}
