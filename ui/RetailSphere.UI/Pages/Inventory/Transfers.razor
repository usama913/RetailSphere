@page "/inventory/transfers"
@using RetailSphere.Contracts.Admin
@using RetailSphere.Contracts.Catalog
@using RetailSphere.Contracts.Inventory
@attribute [Authorize]
@inject IApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>Stock Transfers - RetailSphere</PageTitle>

@if (!_canView)
{
    <MudAlert Severity="Severity.Warning">You don't have permission to view stock transfers.</MudAlert>
}
else
{

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <div>
        <MudText Typo="Typo.h5">Stock Transfers</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Move stock from one branch to another.</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="ShowCreateForm">
        New Transfer
    </MudButton>
</MudStack>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" md="3">
        <MudTextField T="string" Value="@_search" ValueChanged="OnSearchChanged" Label="Search Transfer #"
                      Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="300" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudSelect T="long?" Value="_filterFromBranchId" ValueChanged="OnFilterFromBranchChanged" Label="From branch" Variant="Variant.Outlined">
            <MudSelectItem T="long?" Value="@((long?)null)">All branches</MudSelectItem>
            @foreach (var branch in _branches)
            {
                <MudSelectItem T="long?" Value="@((long?)branch.Id)">@branch.Name</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudSelect T="long?" Value="_filterToBranchId" ValueChanged="OnFilterToBranchChanged" Label="To branch" Variant="Variant.Outlined">
            <MudSelectItem T="long?" Value="@((long?)null)">All branches</MudSelectItem>
            @foreach (var branch in _branches)
            {
                <MudSelectItem T="long?" Value="@((long?)branch.Id)">@branch.Name</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudSelect T="string" Value="_filterStatus" ValueChanged="OnFilterStatusChanged" Label="Status" Variant="Variant.Outlined">
            <MudSelectItem T="string" Value="@string.Empty">All statuses</MudSelectItem>
            @foreach (var status in Statuses)
            {
                <MudSelectItem T="string" Value="@status">@status</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
</MudGrid>

@if (_showForm)
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
            <MudText Typo="Typo.h6">@(_editingId is null ? "New Transfer" : $"Edit {_editingTransferNumber}")</MudText>
            @if (_editingId is not null)
            {
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(_editingStatus)">@_editingStatus</MudChip>
            }
        </MudStack>

        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="long?" @bind-Value="_formFromBranchId" Label="From branch" Variant="Variant.Outlined" Disabled="@(!_isDraftOrNew)">
                    <MudSelectItem T="long?" Value="@((long?)null)">— Select —</MudSelectItem>
                    @foreach (var branch in _branches)
                    {
                        <MudSelectItem T="long?" Value="@((long?)branch.Id)">@branch.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="long?" @bind-Value="_formToBranchId" Label="To branch" Variant="Variant.Outlined" Disabled="@(!_isDraftOrNew)">
                    <MudSelectItem T="long?" Value="@((long?)null)">— Select —</MudSelectItem>
                    @foreach (var branch in _branches)
                    {
                        <MudSelectItem T="long?" Value="@((long?)branch.Id)">@branch.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker @bind-Date="_formTransferDate" Label="Transfer date" Variant="Variant.Outlined" Disabled="@(!_isDraftOrNew)" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_formNotes" Label="Notes" Variant="Variant.Outlined" Lines="2" Disabled="@(!_isDraftOrNew)" />
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-4" Spacing="2" Wrap="Wrap.Wrap">
            @if (_isDraftOrNew)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveHeaderAsync" Disabled="@_isSaving">Save</MudButton>
            }
            @if (_editingId is not null && _editingStatus == "Draft" && _canApprove)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SubmitAsync">Submit</MudButton>
            }
            @if (_editingId is not null && _editingStatus is "Draft" or "Submitted" or "PartiallyReceived" && _canApprove)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CancelTransferAsync">Cancel Transfer</MudButton>
            }
            <MudButton Variant="Variant.Text" OnClick="CloseForm">Close</MudButton>
        </MudStack>

        @if (_editingId is not null)
        {
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle1" Class="mb-2">Lines — Total requested: @_editingLines.Sum(l => l.QuantityRequested)</MudText>

            @if (_editingLines.Count > 0)
            {
                <MudTable Items="@_editingLines" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>SKU / Description</MudTh>
                        <MudTh>Qty requested</MudTh>
                        <MudTh>Qty received</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="SKU / Description">@context.DescriptionSnapshot</MudTd>
                        <MudTd DataLabel="Qty requested">@context.QuantityRequested</MudTd>
                        <MudTd DataLabel="Qty received">@context.QuantityReceived</MudTd>
                        <MudTd DataLabel="Actions">
                            @if (_editingStatus == "Draft")
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => RemoveLineAsync(context.Id))" />
                            }
                            @if (_editingStatus is "Submitted" or "PartiallyReceived" && !context.IsFullyReceived && _canApprove)
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-1">
                                    <MudNumericField T="decimal" Value="@GetReceiveDraft(context.Id)" ValueChanged="@(v => SetReceiveDraft(context.Id, v))"
                                                      Label="Receive qty" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="@context.RemainingQuantity" />
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => ReceiveLineAsync(context.Id))">Receive</MudButton>
                                </MudStack>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }

            @if (_editingStatus == "Draft")
            {
                <MudGrid Class="mt-2">
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="long?" @bind-Value="_lineProductId" Label="Product" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem T="long?" Value="@((long?)null)">— Select —</MudSelectItem>
                            @foreach (var product in _products)
                            {
                                <MudSelectItem T="long?" Value="@((long?)product.Id)">@product.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="long?" @bind-Value="_lineVariantId" Label="Variant" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem T="long?" Value="@((long?)null)">— Select —</MudSelectItem>
                            @foreach (var variant in GetVariantsForSelectedProduct())
                            {
                                <MudSelectItem T="long?" Value="@((long?)variant.Id)">@GetVariantLabel(variant)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudNumericField @bind-Value="_lineQuantity" Label="Quantity" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                    </MudItem>
                </MudGrid>

                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-2" OnClick="AddLineAsync">Add Line</MudButton>
            }
        }
    </MudPaper>
}

<MudTable Items="@_stockTransfers" Hover="true" Dense="true" Loading="@_isLoading">
    <HeaderContent>
        <MudTh>Transfer #</MudTh>
        <MudTh>From</MudTh>
        <MudTh>To</MudTh>
        <MudTh>Transfer date</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Qty</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Transfer #">@context.TransferNumber</MudTd>
        <MudTd DataLabel="From">@(context.FromBranchName ?? "—")</MudTd>
        <MudTd DataLabel="To">@(context.ToBranchName ?? "—")</MudTd>
        <MudTd DataLabel="Transfer date">@context.TransferDate.ToString("yyyy-MM-dd")</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
        </MudTd>
        <MudTd DataLabel="Qty">@context.TotalQuantityRequested</MudTd>
        <MudTd DataLabel="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" OnClick="@(() => ShowEditFormAsync(context.Id))" />
            @if (context.Status == "Draft")
            {
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => DeleteAsync(context.Id))" />
            }
        </MudTd>
    </RowTemplate>
</MudTable>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="mt-4" Spacing="4">
    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Disabled="@(_page <= 1)" OnClick="@(() => ChangePageAsync(_page - 1))" />
    <MudText Typo="Typo.body2">Page @_page of @_totalPages</MudText>
    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Disabled="@(_page >= _totalPages)" OnClick="@(() => ChangePageAsync(_page + 1))" />
</MudStack>

}

@code {
    private const int PageSize = 25;

    private static readonly IReadOnlyList<string> Statuses = ["Draft", "Submitted", "PartiallyReceived", "Received", "Cancelled"];

    private IReadOnlyList<StockTransferDto> _stockTransfers = [];
    private IReadOnlyList<BranchDto> _branches = [];
    private IReadOnlyList<ProductDto> _products = [];
    private IReadOnlyList<ProductAttributeDto> _attributes = [];
    private HashSet<string> _permissions = [];
    private readonly Dictionary<long, decimal> _receiveDrafts = new();

    private bool _isLoading = true;
    private bool _isSaving;
    private string _search = string.Empty;
    private long? _filterFromBranchId;
    private long? _filterToBranchId;
    private string _filterStatus = string.Empty;
    private int _page = 1;
    private long _totalCount;
    private int _totalPages = 1;

    private bool _showForm;
    private long? _editingId;
    private string _editingTransferNumber = string.Empty;
    private string _editingStatus = "Draft";
    private List<StockTransferLineDto> _editingLines = [];

    private long? _formFromBranchId;
    private long? _formToBranchId;
    private DateTime? _formTransferDate = DateTime.UtcNow;
    private string? _formNotes;

    private long? _lineProductId;
    private long? _lineVariantId;
    private decimal _lineQuantity;

    private bool _isDraftOrNew => _editingId is null || _editingStatus == "Draft";

    private bool _canView => _permissions.Contains("inventory.transfer.view");
    private bool _canApprove => _permissions.Contains("inventory.transfer.approve");

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _permissions = state.User.FindAll("permission").Select(c => c.Value).ToHashSet();

        if (_canView)
        {
            var branchesResult = await ApiClient.GetBranchesAsync(includeInactive: true);
            if (branchesResult.Success && branchesResult.Data is not null)
                _branches = branchesResult.Data;

            var productsResult = await ApiClient.GetProductsAsync(1, 1000);
            if (productsResult.Success && productsResult.Data is not null)
                _products = productsResult.Data.Data;

            var attributesResult = await ApiClient.GetProductAttributesAsync();
            if (attributesResult.Success && attributesResult.Data is not null)
                _attributes = attributesResult.Data;

            await LoadAsync();
        }
        else
        {
            _isLoading = false;
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        var result = await ApiClient.GetStockTransfersAsync(
            _page, PageSize, string.IsNullOrWhiteSpace(_search) ? null : _search, _filterFromBranchId, _filterToBranchId,
            string.IsNullOrWhiteSpace(_filterStatus) ? null : _filterStatus);

        if (result.Success && result.Data is not null)
        {
            _stockTransfers = result.Data.Data;
            _totalCount = result.Data.TotalCount;
            _totalPages = Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to load stock transfers.", Severity.Error);
        }

        _isLoading = false;
    }

    private async Task OnSearchChanged(string value)
    {
        _search = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task OnFilterFromBranchChanged(long? value)
    {
        _filterFromBranchId = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task OnFilterToBranchChanged(long? value)
    {
        _filterToBranchId = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task OnFilterStatusChanged(string value)
    {
        _filterStatus = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task ChangePageAsync(int newPage)
    {
        _page = newPage;
        await LoadAsync();
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "Submitted" => Color.Info,
        "PartiallyReceived" => Color.Warning,
        "Received" => Color.Success,
        "Cancelled" => Color.Error,
        _ => Color.Default,
    };

    private IReadOnlyList<ProductVariantDto> GetVariantsForSelectedProduct()
    {
        if (_lineProductId is null) return [];
        var product = _products.FirstOrDefault(p => p.Id == _lineProductId.Value);
        return product?.Variants ?? [];
    }

    /// <summary>SKU plus its attribute values (e.g. "P5-V07 — Size: 39") so variants aren't just an opaque code in the dropdown.</summary>
    private string GetVariantLabel(ProductVariantDto variant)
    {
        if (variant.AttributeValueIds.Count == 0)
            return variant.Sku;

        var parts = new List<string>();
        foreach (var attribute in _attributes)
        {
            var matched = attribute.Values
                .Where(v => variant.AttributeValueIds.Contains(v.Id))
                .Select(v => v.Value)
                .ToList();

            if (matched.Count > 0)
                parts.Add($"{attribute.Name}: {string.Join(", ", matched)}");
        }

        return parts.Count > 0 ? $"{variant.Sku} — {string.Join(" · ", parts)}" : variant.Sku;
    }

    private decimal GetReceiveDraft(long lineId) => _receiveDrafts.TryGetValue(lineId, out var value) ? value : 0;

    private void SetReceiveDraft(long lineId, decimal value) => _receiveDrafts[lineId] = value;

    private void ShowCreateForm()
    {
        _editingId = null;
        _editingTransferNumber = string.Empty;
        _editingStatus = "Draft";
        _editingLines = [];
        _formFromBranchId = null;
        _formToBranchId = null;
        _formTransferDate = DateTime.UtcNow;
        _formNotes = null;
        ResetLineForm();
        _showForm = true;
    }

    private async Task ShowEditFormAsync(long id)
    {
        var result = await ApiClient.GetStockTransferByIdAsync(id);
        if (!result.Success || result.Data is null)
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to load stock transfer.", Severity.Error);
            return;
        }

        var transfer = result.Data;
        _editingId = transfer.Id;
        _editingTransferNumber = transfer.TransferNumber;
        _editingStatus = transfer.Status;
        _editingLines = transfer.Lines.ToList();
        _formFromBranchId = transfer.FromBranchId;
        _formToBranchId = transfer.ToBranchId;
        _formTransferDate = transfer.TransferDate;
        _formNotes = transfer.Notes;
        ResetLineForm();
        _showForm = true;
    }

    private void ResetLineForm()
    {
        _lineProductId = null;
        _lineVariantId = null;
        _lineQuantity = 0;
    }

    private void CloseForm() => _showForm = false;

    private async Task SaveHeaderAsync()
    {
        if (_formFromBranchId is null || _formToBranchId is null || _formTransferDate is null)
        {
            Snackbar.Add("From branch, to branch, and transfer date are required.", Severity.Warning);
            return;
        }

        if (_formFromBranchId == _formToBranchId)
        {
            Snackbar.Add("Source and destination branches must be different.", Severity.Warning);
            return;
        }

        _isSaving = true;

        if (_editingId is null)
        {
            var createResult = await ApiClient.CreateStockTransferAsync(new CreateStockTransferRequest
            {
                FromBranchId = _formFromBranchId.Value,
                ToBranchId = _formToBranchId.Value,
                TransferDate = _formTransferDate.Value,
                Notes = _formNotes,
            });

            if (createResult.Success && createResult.Data is not null)
            {
                Snackbar.Add("Transfer created — you can now add lines below.", Severity.Success);
                _editingId = createResult.Data.Id;
                _editingTransferNumber = createResult.Data.TransferNumber;
                _editingStatus = createResult.Data.Status;
                _editingLines = createResult.Data.Lines.ToList();
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(createResult.Error?.Message ?? "Failed to create transfer.", Severity.Error);
            }
        }
        else
        {
            var updateResult = await ApiClient.UpdateStockTransferAsync(_editingId.Value, new UpdateStockTransferRequest
            {
                FromBranchId = _formFromBranchId.Value,
                ToBranchId = _formToBranchId.Value,
                TransferDate = _formTransferDate.Value,
                Notes = _formNotes,
            });

            if (updateResult.Success)
            {
                Snackbar.Add("Transfer saved.", Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(updateResult.Error?.Message ?? "Failed to save transfer.", Severity.Error);
            }
        }

        _isSaving = false;
    }

    private async Task AddLineAsync()
    {
        if (_editingId is null || _lineProductId is null || _lineVariantId is null)
        {
            Snackbar.Add("Select a product and variant first.", Severity.Warning);
            return;
        }

        var result = await ApiClient.AddStockTransferLineAsync(_editingId.Value, new AddStockTransferLineRequest
        {
            ProductId = _lineProductId.Value,
            ProductVariantId = _lineVariantId.Value,
            QuantityRequested = _lineQuantity,
        });

        if (result.Success && result.Data is not null)
        {
            Snackbar.Add("Line added.", Severity.Success);
            _editingLines = result.Data.Lines.ToList();
            ResetLineForm();
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to add line.", Severity.Error);
        }
    }

    private async Task RemoveLineAsync(long lineId)
    {
        if (_editingId is null) return;

        var result = await ApiClient.RemoveStockTransferLineAsync(_editingId.Value, lineId);
        if (result.Success && result.Data is not null)
        {
            Snackbar.Add("Line removed.", Severity.Success);
            _editingLines = result.Data.Lines.ToList();
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to remove line.", Severity.Error);
        }
    }

    private async Task ReceiveLineAsync(long lineId)
    {
        if (_editingId is null) return;

        var quantity = GetReceiveDraft(lineId);
        if (quantity <= 0)
        {
            Snackbar.Add("Enter a quantity to receive.", Severity.Warning);
            return;
        }

        var result = await ApiClient.ReceiveStockTransferLineAsync(_editingId.Value, lineId, new ReceiveStockTransferLineRequest { Quantity = quantity });
        if (result.Success && result.Data is not null)
        {
            Snackbar.Add("Received.", Severity.Success);
            _editingStatus = result.Data.Status;
            _editingLines = result.Data.Lines.ToList();
            _receiveDrafts.Remove(lineId);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to receive quantity.", Severity.Error);
        }
    }

    private async Task SubmitAsync()
    {
        if (_editingId is null) return;

        var result = await ApiClient.SubmitStockTransferAsync(_editingId.Value);
        if (result.Success && result.Data is not null)
        {
            Snackbar.Add("Transfer submitted.", Severity.Success);
            _editingStatus = result.Data.Status;
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to submit transfer.", Severity.Error);
        }
    }

    private async Task CancelTransferAsync()
    {
        if (_editingId is null) return;

        var result = await ApiClient.CancelStockTransferAsync(_editingId.Value);
        if (result.Success && result.Data is not null)
        {
            Snackbar.Add("Transfer cancelled.", Severity.Success);
            _editingStatus = result.Data.Status;
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to cancel transfer.", Severity.Error);
        }
    }

    private async Task DeleteAsync(long id)
    {
        var result = await ApiClient.DeleteStockTransferAsync(id);
        if (result.Success)
        {
            Snackbar.Add("Transfer deleted.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Failed to delete transfer.", Severity.Error);
        }
    }
}
