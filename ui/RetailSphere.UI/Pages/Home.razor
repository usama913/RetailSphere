@page "/"
@attribute [Authorize]

<PageTitle>Dashboard - RetailSphere</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Today's Sales</MudText>
            <MudText Typo="Typo.h5">—</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Low Stock Alerts</MudText>
            <MudText Typo="Typo.h5">—</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Open Cash Registers</MudText>
            <MudText Typo="Typo.h5">—</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Pending Purchase Orders</MudText>
            <MudText Typo="Typo.h5">—</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudAlert Severity="Severity.Info" Class="mt-6">
    This is the Phase 0 foundations shell — role-specific dashboard widgets (sales trend, top SKUs,
    reorder alerts) are built out starting with the Catalog/Inventory/Sales modules per the roadmap.
</MudAlert>
