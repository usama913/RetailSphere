@using System.Security.Claims
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject JwtAuthenticationStateProvider JwtAuthStateProvider

<MudAppBar Elevation="0" Class="rs-appbar">
    <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="@(() => OnToggleDrawer.InvokeAsync())" />

    <MudText Typo="Typo.subtitle1" Class="ml-3" Style="opacity: 0.95;">
        @_greeting
    </MudText>

    <MudSpacer />

    <MudTooltip Text="Notifications">
        <MudIconButton Icon="@Icons.Material.Filled.NotificationsNone" Color="Color.Inherit" />
    </MudTooltip>

    <MudTooltip Text="@(IsDarkMode ? "Switch to light mode" : "Switch to dark mode")">
        <MudIconButton Icon="@(IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@(() => OnToggleTheme.InvokeAsync())" />
    </MudTooltip>

    <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="ml-2">
        <ActivatorContent>
            <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Small" Style="cursor: pointer;">
                @_initials
            </MudAvatar>
        </ActivatorContent>
        <ChildContent>
            <MudMenuItem Disabled="true">@_displayName</MudMenuItem>
            <MudDivider />
            <MudMenuItem OnClick="LogoutAsync" Icon="@Icons.Material.Filled.Logout">Log out</MudMenuItem>
        </ChildContent>
    </MudMenu>
</MudAppBar>

@code {
    [Parameter] public EventCallback OnToggleDrawer { get; set; }
    [Parameter] public EventCallback OnToggleTheme { get; set; }
    [Parameter] public bool IsDarkMode { get; set; }

    private string _displayName = "Account";
    private string _initials = "?";
    private string _greeting = "Welcome";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _displayName = state.User.FindFirst(ClaimTypes.Email)?.Value
            ?? state.User.FindFirst("email")?.Value
            ?? "Account";

        _initials = _displayName == "Account" ? "?" : _displayName[..1].ToUpperInvariant();

        var hour = DateTime.Now.Hour;
        string timeOfDay;
        if (hour < 12)
        {
            timeOfDay = "morning";
        }
        else if (hour < 17)
        {
            timeOfDay = "afternoon";
        }
        else
        {
            timeOfDay = "evening";
        }
        _greeting = $"Good {timeOfDay}";
    }

    private async Task LogoutAsync()
    {
        await JwtAuthStateProvider.LogoutAsync();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}
