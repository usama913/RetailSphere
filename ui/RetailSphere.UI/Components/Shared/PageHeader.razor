@namespace RetailSphere.UI.Components.Shared

<MudStack Spacing="1" Class="mb-4">
    @if (Breadcrumbs is { Count: > 0 })
    {
        <MudBreadcrumbs Items="Breadcrumbs" Class="pa-0 mb-1" />
    }
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
        <div>
            <MudText Typo="Typo.h5">@Title</MudText>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">@Subtitle</MudText>
            }
        </div>
        @if (Actions is not null)
        {
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                @Actions
            </MudStack>
        }
    </MudStack>
</MudStack>

@code {
    /// <summary>Page title, shown as an h5 — the same size every page used to set individually.</summary>
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;

    /// <summary>One-line description shown under the title, matching the existing "body2 secondary-color" convention.</summary>
    [Parameter] public string? Subtitle { get; set; }

    /// <summary>
    /// Optional breadcrumb trail (e.g. Dashboard -> Catalog -> Categories). Omit the
    /// href on the last item so it renders as the non-clickable "current page" crumb.
    /// This is the app-wide answer to "no way to see where you are / get back" — see
    /// the UI/UX audit's Navigation requirement.
    /// </summary>
    [Parameter] public List<BreadcrumbItem>? Breadcrumbs { get; set; }

    /// <summary>Primary action button(s) — e.g. "New Category" — rendered top-right, same slot on every page.</summary>
    [Parameter] public RenderFragment? Actions { get; set; }
}
